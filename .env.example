# ============================================================
# ClubOS - Umgebungsvariablen
# ============================================================
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env
#
# Oder nutze das Installationsskript:
#   ./install.sh
# ============================================================

# ---- Datenbank (PostgreSQL) ----
DB_NAME=clubos
DB_USER=clubos
DB_PASSWORD=                          # PFLICHT - wird von install.sh generiert
DATABASE_URL=postgresql://clubos:DEIN_PASSWORT@postgres:5432/clubos

# ---- Redis ----
REDIS_URL=redis://redis:6379

# ---- JWT Authentifizierung ----
JWT_SECRET=                           # PFLICHT - wird von install.sh generiert
JWT_REFRESH_SECRET=                   # PFLICHT - wird von install.sh generiert
JWT_EXPIRATION=15m                    # Access Token Lebensdauer
JWT_REFRESH_EXPIRATION=7d             # Refresh Token Lebensdauer

# ---- Backend ----
PORT=3001
NODE_ENV=production

# ---- Domain & URLs ----
DOMAIN=localhost                      # Deine Domain, z.B. clubos.meinverein.de
FRONTEND_URL=http://localhost:3000    # Wird bei Domain-Aenderung angepasst
NEXT_PUBLIC_API_URL=http://localhost:3001  # API-URL fuer das Frontend

# ---- SSL / Let's Encrypt (nur bei Domain != localhost) ----
ACME_EMAIL=                           # E-Mail fuer SSL-Zertifikate

# ---- E-Mail / SMTP (optional) ----
# Fuer Einladungen, Erinnerungen und Benachrichtigungen
SMTP_HOST=                            # z.B. smtp.brevo.com
SMTP_PORT=587                         # 587 fuer STARTTLS, 465 fuer SSL
SMTP_USER=                            # SMTP Benutzername
SMTP_PASS=                            # SMTP Passwort
SMTP_FROM=                            # Absender, z.B. noreply@meinverein.de

# ---- KI-Integration (optional) ----
# Fuer automatische Formular-Erkennung (PDF/DOCX -> Digital)
KI_PROVIDER=                          # anthropic oder openai
ANTHROPIC_API_KEY=                    # Anthropic API Key
OPENAI_API_KEY=                       # OpenAI API Key

# ---- S3 Storage / Hetzner ObjectStorage (optional) ----
# Fuer Datei-Uploads (Logos, Dokumente, Formulare)
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=

# ---- Port-Konfiguration (optional, fuer localhost-Modus) ----
# BACKEND_PORT=3001                   # Externer Backend-Port
# FRONTEND_PORT=3000                  # Externer Frontend-Port
