generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== Verein (Tenant) ====================

model Tenant {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  logo         String?
  primaryColor String   @default("#1a56db")
  plan         Plan     @default(STARTER)
  domain       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users              User[]
  abteilungen        Abteilung[]
  teams              Team[]
  events             Event[]
  tournaments        Tournament[]
  members            Member[]
  formTemplates      FormTemplate[]
  formSubmissions    FormSubmission[]
  messages           Message[]
  faqs               FAQ[]
  fahrgemeinschaften Fahrgemeinschaft[]
  dokumente          Dokument[]
  workflows          Workflow[]
  hallen             Halle[]
  sponsoren          Sponsor[]

  @@index([slug])
}

enum Plan {
  STARTER
  PRO
  CLUB
  ENTERPRISE
  SELF_HOSTED
}

// ==================== Benutzer ====================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  role         Role
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshToken String?
  profile      Member?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
  @@index([email])
}

enum Role {
  SUPERADMIN
  ADMIN
  TRAINER
  MEMBER
  PARENT
}

// ==================== Mitglied ====================

model Member {
  id           String       @id @default(cuid())
  userId       String?      @unique
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberNumber String
  firstName    String
  lastName     String
  email        String?
  birthDate    DateTime?
  phone        String?
  address      String?
  joinDate     DateTime     @default(now())
  exitDate     DateTime?
  status       MemberStatus @default(PENDING)
  sport        String[]
  qrCode       String?
  parentEmail  String?
  signatureUrl String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  attendances  Attendance[]
  teamMembers  TeamMember[]

  @@index([tenantId])
  @@index([email])
}

enum MemberStatus {
  PENDING
  ACTIVE
  INACTIVE
  CANCELLED
}

// ==================== Abteilung (z.B. Fussball, Handball) ====================

model Abteilung {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String   // z.B. "Fussball", "Handball"
  sport       Sport
  leiterIds   String[] // UserIDs der Abteilungsleiter
  beschreibung String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teams       Team[]

  @@unique([tenantId, sport])
  @@index([tenantId])
}

// ==================== Mannschaft ====================

model Team {
  id           String  @id @default(cuid())
  name         String
  sport        Sport
  ageGroup     String
  trainerId    String
  tenantId     String
  tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  abteilungId  String?
  abteilung    Abteilung? @relation(fields: [abteilungId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  events           Event[]
  messages         Message[]
  teamMembers      TeamMember[]
  hallenbelegungen Hallenbelegung[]

  @@index([tenantId])
  @@index([abteilungId])
}

// ==================== Kader (Team-Mitglieder) ====================

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  rolle     String   @default("SPIELER")
  createdAt DateTime @default(now())

  @@unique([teamId, memberId])
  @@index([teamId])
  @@index([memberId])
}

enum Sport {
  FUSSBALL
  HANDBALL
  BASKETBALL
  FOOTBALL
  TENNIS
  TURNEN
  SCHWIMMEN
  LEICHTATHLETIK
  SONSTIGES
}

// ==================== Veranstaltungen ====================

model Event {
  id          String    @id @default(cuid())
  title       String
  type        EventType
  date        DateTime
  endDate     DateTime?
  location    String
  hallName    String?
  hallAddress String?
  teamId      String
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  notes       String?
  // Wiederkehrende Events
  recurrenceRule  String?   // z.B. "WEEKLY:DI,DO" oder "BIWEEKLY:MI"
  recurrenceEnd   DateTime? // Bis wann wiederholen
  parentEventId   String?   // Referenz auf das Eltern-Event (Vorlage)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  attendances      Attendance[]
  reminders        Reminder[]
  comments         EventComment[]
  schnellTokens    SchnellAnmeldungToken[]

  @@index([tenantId])
  @@index([teamId])
  @@index([date])
}

// ==================== Event-Kommentare ====================

model EventComment {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  content   String
  createdAt DateTime @default(now())

  @@index([eventId])
}

enum EventType {
  TRAINING
  MATCH
  TOURNAMENT
  TRIP
  MEETING
}

// ==================== Anwesenheit ====================

model Attendance {
  id         String           @id @default(cuid())
  eventId    String
  event      Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  memberId   String
  member     Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  status     AttendanceStatus @default(PENDING)
  reason     String?
  answeredAt DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([eventId, memberId])
  @@index([eventId])
  @@index([memberId])
}

enum AttendanceStatus {
  PENDING
  YES
  NO
  MAYBE
}

// ==================== Turnier ====================

model Tournament {
  id        String          @id @default(cuid())
  name      String
  sport     Sport
  format    TournamentFormat
  publicUrl String          @unique
  tenantId  String
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  isLive    Boolean         @default(false)
  qrCode    String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  matches TournamentMatch[]

  @@index([tenantId])
  @@index([publicUrl])
}

enum TournamentFormat {
  GRUPPE
  KO
  SCHWEIZER
  KOMBINATION
}

model TournamentMatch {
  id           String      @id @default(cuid())
  tournamentId String
  tournament   Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team1        String
  team2        String
  score1       Int?
  score2       Int?
  time         DateTime?
  field        String?
  status       MatchStatus @default(GEPLANT)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([tournamentId])
}

enum MatchStatus {
  GEPLANT
  LAUFEND
  BEENDET
  ABGESAGT
}

// ==================== Formulare ====================

model FormTemplate {
  id       String   @id @default(cuid())
  tenantId String
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name     String
  type     FormType
  fileUrl  String
  fields   Json
  isActive Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissions FormSubmission[]

  @@index([tenantId])
}

enum FormType {
  MITGLIEDSANTRAG
  EINVERSTAENDNIS
  DATENSCHUTZ
  SONSTIGES
}

// ==================== Formular-Einreichungen (Online-Antraege) ====================

model FormSubmission {
  id             String           @id @default(cuid())
  tenantId       String
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  templateId     String
  template       FormTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  eingereichtVon String?          // userId, falls angemeldet
  email          String           // E-Mail des Antragstellers
  daten          Json             // Ausgefuellte Felder als JSON
  signatureUrl   String?          // Digitale Unterschrift als Data-URL
  status         SubmissionStatus @default(EINGEREICHT)
  kommentar      String?          // Interner Kommentar vom Admin
  archiviertePdf String?          // URL der archivierten PDF
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([tenantId])
  @@index([templateId])
  @@index([status])
}

enum SubmissionStatus {
  EINGEREICHT   // Antrag gestellt
  IN_PRUEFUNG   // Wird geprueft
  GENEHMIGT     // Genehmigt → Mitglied wird angelegt
  ABGELEHNT     // Abgelehnt
  ARCHIVIERT    // Archiviert
}

// ==================== Dokumenten-Ablage ====================

model Dokument {
  id          String       @id @default(cuid())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  beschreibung String?
  dateiUrl    String       // Pfad im S3/Storage
  dateiGroesse Int         // Groesse in Bytes
  dateiTyp    String       // MIME-Type (application/pdf, image/png, etc.)
  kategorie   DokumentKategorie @default(SONSTIGES)
  ordner      String?      // Optionaler Ordner-Pfad
  hochgeladenVon String    // userId
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([tenantId])
  @@index([kategorie])
  @@index([ordner])
}

enum DokumentKategorie {
  MITGLIEDSANTRAG
  VERTRAG
  RECHNUNG
  PROTOKOLL
  TRAININGSPLAN
  SATZUNG
  DATENSCHUTZ
  SONSTIGES
}

// ==================== Erinnerungen ====================

model Reminder {
  id           String       @id @default(cuid())
  eventId      String
  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  type         ReminderType
  sentAt       DateTime?
  scheduledFor DateTime
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([eventId])
  @@index([scheduledFor])
}

enum ReminderType {
  H24
  H2
  CUSTOM
}

// ==================== Nachrichten ====================

model Message {
  id         String      @id @default(cuid())
  tenantId   String
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teamId     String?
  team       Team?       @relation(fields: [teamId], references: [id], onDelete: SetNull)
  senderId   String
  content    String
  type       MessageType
  silentFrom String?
  silentTo   String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  reads MessageRead[]

  @@index([tenantId])
  @@index([teamId])
}

enum MessageType {
  BROADCAST
  ANNOUNCEMENT
  TEAM_CHAT
  QUESTION
  FAQ_ANSWER
}

model MessageRead {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  readAt    DateTime @default(now())

  @@unique([messageId, userId])
  @@index([messageId])
}

// ==================== FAQ ====================

model FAQ {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teamId   String?
  question String
  answer   String
  useCount Int    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// ==================== Schnell-Anmeldung per E-Mail-Link ====================

model SchnellAnmeldungToken {
  id        String   @id @default(cuid())
  token     String   @unique
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  memberId  String
  benutzt   Boolean  @default(false)
  gueltigBis DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([eventId])
}

// ==================== Fahrtenborse ====================

model Fahrgemeinschaft {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  eventId     String?
  fahrerId    String   // userId des Fahrers
  startort    String
  zielort     String
  abfahrt     DateTime
  plaetze     Int      @default(4)
  kommentar   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mitfahrer   Mitfahrer[]

  @@index([tenantId])
  @@index([eventId])
}

model Mitfahrer {
  id                 String           @id @default(cuid())
  fahrgemeinschaftId String
  fahrgemeinschaft   Fahrgemeinschaft @relation(fields: [fahrgemeinschaftId], references: [id], onDelete: Cascade)
  userId             String
  createdAt          DateTime         @default(now())

  @@unique([fahrgemeinschaftId, userId])
  @@index([fahrgemeinschaftId])
}

// ==================== Schiedsrichter-Einteilung ====================

model SchiedsrichterEinteilung {
  id         String   @id @default(cuid())
  tenantId   String
  eventId    String
  memberId   String   // Mitglied das als Schiedsrichter eingeteilt ist
  status     SchiriStatus @default(EINGETEILT)
  bestaetigt Boolean  @default(false)
  notiz      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([eventId, memberId])
  @@index([tenantId])
  @@index([eventId])
}

enum SchiriStatus {
  EINGETEILT
  BESTAETIGT
  ABGELEHNT
  ERSATZ
}

// ==================== Buchhaltung / SEPA ====================

model Rechnung {
  id           String          @id @default(cuid())
  tenantId     String
  memberId     String
  rechnungsNr  String
  betrag       Float
  beschreibung String
  faelligAm    DateTime
  bezahltAm    DateTime?
  status       RechnungStatus  @default(OFFEN)
  sepaMandat   String?         // SEPA-Mandatsreferenz
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([tenantId])
  @@index([memberId])
  @@index([status])
}

enum RechnungStatus {
  OFFEN
  BEZAHLT
  UEBERFAELLIG
  STORNIERT
}

model Beitrag {
  id          String   @id @default(cuid())
  tenantId    String
  name        String   // z.B. "Jahresbeitrag Erwachsene"
  betrag      Float
  intervall   String   // MONATLICH, QUARTALSWEISE, JAEHRLICH
  sportart    String?  // Optional: nur fuer bestimmte Sportart
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

// ==================== Workflows (Einladungs-Pakete) ====================

model Workflow {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String   // z.B. "Neues Mitglied Fussball"
  beschreibung String?  // z.B. "Alle Unterlagen fuer neue Fussball-Mitglieder"
  templateIds  String[] // Welche Formulare gesendet werden
  sportarten   String[] // Vorbelegte Sportarten
  emailBetreff String?  // Optionaler eigener E-Mail-Betreff
  emailText    String?  // Optionaler eigener E-Mail-Text
  istAktiv     Boolean  @default(true)
  erstelltVon  String   // userId des Erstellers (Admin/Vorstand)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
}

// ==================== Hallenbelegung ====================

model Halle {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  adresse     String?
  kapazitaet  Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  belegungen  Hallenbelegung[]

  @@index([tenantId])
}

model Hallenbelegung {
  id        String   @id @default(cuid())
  halleId   String
  halle     Halle    @relation(fields: [halleId], references: [id], onDelete: Cascade)
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  wochentag String   // MO, DI, MI, DO, FR, SA, SO
  von       String   // "18:00"
  bis       String   // "20:00"
  notiz     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([halleId])
  @@index([teamId])
}

// ==================== Sponsoren ====================

model Sponsor {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  logoUrl      String?
  webseite     String?
  beschreibung String?
  kontaktName  String?
  kontaktEmail String?
  istAktiv     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
}

// ==================== Einladungen ====================

model Einladung {
  id            String          @id @default(cuid())
  tenantId      String
  token         String          @unique
  vorname       String
  nachname      String
  email         String
  templateIds   String[]        // Mehrere Formulare (Antrag, EWE, Datenschutz)
  sportarten    String[]        // Sportarten fuer die Anmeldung
  geburtsdatum  String?         // Optionales Geburtsdatum
  workflowId    String?         // Welcher Workflow verwendet wurde
  status        EinladungStatus @default(GESENDET)
  eingeladenVon String          // userId des Trainers/Vorstands
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([token])
  @@index([tenantId])
}

enum EinladungStatus {
  GESENDET      // E-Mail verschickt
  GEOEFFNET     // Link wurde geklickt
  AUSGEFUELLT   // Formular wurde ausgefuellt
  ABGELAUFEN    // Token abgelaufen (30 Tage)
}
