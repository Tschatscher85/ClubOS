generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== Verein (Tenant) ====================

model Tenant {
  id                           String    @id @default(cuid())
  name                         String
  slug                         String    @unique
  logo                         String?
  primaryColor                 String    @default("#1a56db")
  plan                         Plan      @default(STARTER)
  domain                       String?
  kiFreigeschaltet             Boolean   @default(false) // Superadmin schaltet KI pro Verein frei
  kiProvider                   String    @default("anthropic")
  kiApiKey                     String?
  kiModell                     String?
  // Vereinsdaten (Pflicht fuer Impressum/Rechtliches)
  vereinsNr                    String? // Vereinsregisternummer (z.B. VR 12345)
  amtsgericht                  String? // Zustaendiges Amtsgericht
  gruendungsjahr               Int?
  anschrift                    String? // Vereinsadresse
  plz                          String?
  ort                          String?
  bundesland                   String?
  telefon                      String?
  email                        String? // Offizielle Vereins-E-Mail
  webseite                     String?
  // Vorstand / Vertretungsberechtigte
  vorstand1Name                String? // 1. Vorsitzender
  vorstand1Funktion            String? // z.B. "1. Vorsitzender"
  vorstand2Name                String? // 2. Vorsitzender
  vorstand2Funktion            String?
  kassenwart                   String?
  schriftfuehrer               String?
  jugendwart                   String?
  // Rechtliches
  satzungUrl                   String? // Hochgeladene Satzung (PDF)
  satzungDatum                 DateTime? // Datum der aktuellen Satzung
  impressum                    String? // Freitext Impressum (HTML)
  datenschutzUrl               String? // Datenschutzerklaerung (PDF oder URL)
  datenschutzText              String? // Freitext Datenschutz (HTML)
  // Versicherungen
  haftpflichtVersicherung      String? // Vereinshaftpflicht Anbieter
  haftpflichtPoliceNr          String? // Policennummer
  haftpflichtGueltigBis        DateTime?
  unfallVersicherung           String? // Sportlunfallversicherung
  unfallPoliceNr               String?
  unfallGueltigBis             DateTime?
  gewaehrleistungsVersicherung String? // D&O / Vermoegens­schaden­haftpflicht
  // Finanzen
  steuernummer                 String? // Steuernummer
  finanzamt                    String? // Zustaendiges Finanzamt
  gemeinnuetzigBis             DateTime? // Gemeinnuetzigkeitsbescheid gueltig bis
  gemeinnuetzigUrl             String? // Freistellungsbescheid (PDF)
  iban                         String? // Vereins-IBAN
  bic                          String?
  bankName                     String?
  // SMTP (globaler Vereins-Mailserver)
  smtpHost                     String?
  smtpPort                     Int?      @default(587)
  smtpUser                     String?
  smtpPass                     String? // Base64-kodiert
  smtpAbsenderEmail            String? // z.B. info@fckunchen.de
  smtpAbsenderName             String? // z.B. "FC Kunchen 1920 e.V."
  // Sportverband-Mitgliedschaften
  landessportbund              String? // z.B. "WLSB - Wuerttembergischer LSB"
  sportverband                 String? // z.B. "WFV - Wuerttembergischer FV"
  verbandsMitgliedsNr          String? // Mitgliedsnummer beim Verband
  // Aktive vordefinierte Sportarten (nur diese erscheinen in Formularen)
  aktiveSportarten             String[] @default([])
  // Konfigurierbare Altersklassen (erscheinen in Team-Formularen)
  altersklassen                String[] @default([])
  // Konfigurierbare Veranstaltungstypen (zusaetzlich zu System-Typen)
  veranstaltungsTypen          String[] @default([])
  // Stripe Billing
  stripeCustomerId             String?
  stripeSubscriptionId         String?
  trialEndsAt                  DateTime?
  // Tenant-Status (Superadmin-Verwaltung)
  istAktiv                     Boolean   @default(true)
  gesperrtAm                   DateTime?
  gesperrtGrund                String?
  zahlungsFehlschlaege         Int       @default(0)
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  users              User[]
  abteilungen        Abteilung[]
  teams              Team[]
  events             Event[]
  tournaments        Tournament[]
  members            Member[]
  formTemplates      FormTemplate[]
  formSubmissions    FormSubmission[]
  messages           Message[]
  faqs               FAQ[]
  fahrgemeinschaften Fahrgemeinschaft[]
  dokumente          Dokument[]
  workflows          Workflow[]
  hallen             Halle[]
  sponsoren          Sponsor[]
  homepage           Homepage?
  customSportarten   CustomSportart[]
  pinboardItems      PinboardItem[]
  rollenVorlagen     RollenVorlage[]
  spielberichte      Spielbericht[]
  ressourcen         Ressource[]
  trainingsplaene    Trainingsplan[]
  verletzungen       Verletzung[]
  aufstellungen      Aufstellung[]
  entwicklungsboegen Entwicklungsbogen[]
  referral           Referral?
  beitragsklassen    Beitragsklasse[]
  umfragen           Umfrage[]
  aushaenge          Aushang[]
  marktplatzInserate MarktplatzInserat[]
  ehrenamtAufgaben   EhrenamtAufgabe[]
  uebungsleiterStunden UebungsleiterStunden[]
  wikiSeiten         WikiSeite[]
  fundingProjekte    FundingProjekt[]
  vereinsPartner     VereinsPartner[]

  @@index([slug])
}

// ==================== Plattform-Konfiguration (Superadmin) ====================

model PlattformConfig {
  id                  String   @id @default("singleton")
  anthropicApiKey     String?  // Plattform Anthropic API Key
  openaiApiKey        String?  // Plattform OpenAI API Key
  standardProvider    String   @default("anthropic") // anthropic oder openai
  standardModell      String?  // Standard-Modell (optional)
  // Globale SMTP-Einstellungen (Superadmin, Web-UI)
  smtpHost            String?
  smtpPort            Int?     @default(587)
  smtpUser            String?
  smtpPass            String?
  smtpFrom            String?  // z.B. "info@vereinbase.de"
  smtpFromName        String?  // z.B. "Vereinbase"
  // Globale IMAP-Einstellungen
  imapHost            String?
  imapPort            Int?     @default(993)
  imapUser            String?
  imapPass            String?
  updatedAt           DateTime @updatedAt
}

enum Plan {
  STARTER
  PRO
  CLUB
  ENTERPRISE
  SELF_HOSTED
}

// ==================== Benutzer ====================

model User {
  id                     String              @id @default(cuid())
  email                  String              @unique
  passwordHash           String?
  role                   Role
  tenantId               String
  tenant                 Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshToken           String?
  // E-Mail-Verifizierung
  emailVerifiziert       Boolean             @default(false)
  emailVerifyToken       String?             @unique
  emailVerifyExpiresAt   DateTime?
  // Passwort vergessen
  passwortResetToken     String?             @unique
  passwortResetExpiresAt DateTime?
  // Google OAuth
  googleId               String?             @unique
  // 2-Faktor-Authentifizierung (TOTP)
  twoFactorSecret        String?
  twoFactorEnabled       Boolean             @default(false)
  backupCodes            String[]
  // Vereinsrollen (mehrere moeglich, z.B. ["Trainer","Kassenpruefer"])
  vereinsRollen          String[] // Verweise auf RollenVorlage.name
  // Berechtigungen (berechnet aus Vereinsrollen + individuelle Anpassungen)
  berechtigungen         String[] // z.B. ["MITGLIEDER","TEAMS","KALENDER","TURNIERE","NACHRICHTEN","BUCHHALTUNG","FORMULARE","DOKUMENTE","EINSTELLUNGEN"]
  istAktiv               Boolean             @default(true)
  letzterLogin           DateTime?
  eingeladenVon          String? // userId des Einladenden
  notizen                String? // Admin-Notizen zum Benutzer
  profile                Member?
  emailEinstellungen     EmailEinstellungen?
  buchungen              Buchung[]
  webPushSubscriptions   WebPushSubscription[]
  familieMitgliedschaften FamilieMitglied[]
  trainerLizenzen        TrainerLizenz[]
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  @@index([tenantId])
  @@index([email])
}

enum Role {
  SUPERADMIN
  ADMIN
  TRAINER
  MEMBER
  PARENT
  HALLENWART  // Gemeinde/Stadt: nur Belegungsplan sehen und verwalten
}

// ==================== Rollen-Vorlagen (pro Verein konfigurierbar) ====================

model RollenVorlage {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String // z.B. "Vorstand", "Trainer", "Kassenpruefer"
  beschreibung   String? // Kurze Beschreibung der Rolle
  systemRolle    Role // Welches System-Zugriffslevel (hoechste gewinnt)
  berechtigungen String[] // Welche Berechtigungen diese Rolle mitbringt
  farbe          String? // Optionale Badge-Farbe (Hex)
  sortierung     Int      @default(0) // Reihenfolge in der Anzeige
  istStandard    Boolean  @default(false) // Vom System vorgegeben (nicht loeschbar)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
}

// ==================== Mitglied ====================

model Member {
  id                         String         @id @default(cuid())
  userId                     String?        @unique
  user                       User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  tenantId                   String
  tenant                     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberNumber               String
  firstName                  String
  lastName                   String
  email                      String?
  birthDate                  DateTime?
  phone                      String?
  address                    String?
  joinDate                   DateTime       @default(now())
  exitDate                   DateTime?
  status                     MemberStatus   @default(PENDING)
  sport                      String[]
  qrCode                     String?
  profilBildUrl              String?    // Profilbild (Upload durch Admin/Trainer/Eltern)
  parentEmail                String?
  signatureUrl               String?
  // Beitrag & Ermaessigung
  beitragsArt                String? // z.B. "Jahresbeitrag Erwachsene", "Jugend", "Familie"
  beitragBetrag              Float? // Individueller Beitrag (ueberschreibt Standard)
  beitragIntervall           String? // MONATLICH, QUARTALSWEISE, HALBJAEHRLICH, JAEHRLICH
  ermaessigung               Ermaessigung? // Ermaessigungsgrund
  ermaessigungProzent        Float? // z.B. 50 fuer 50% Ermaessigung
  ermaessigungBis            DateTime? // Gueltig bis (z.B. Ende Semester)
  nachweisDokUrl             String? // Hochgeladener Nachweis (Studentenausweis, etc.)
  nachweisStatus             NachweisStatus @default(NICHT_ERFORDERLICH)
  nachweisErinnerungGesendet DateTime? // Wann letzte Erinnerung gesendet wurde
  beitragsklasseId           String? // Verknuepfung zur Beitragsklasse
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt

  // Einverstaendniserklaerungen (DSGVO + Aufsichtspflicht)
  fotoErlaubnis                Boolean   @default(false) // Eltern erlauben Fotos (KUG §22, DSGVO Art. 6)
  fotoErlaubnisAm              DateTime? // Datum der Einwilligung
  fahrgemeinschaftErlaubnis    Boolean   @default(false) // Eltern erlauben Mitfahrt (§832 BGB Aufsichtspflicht)
  fahrgemeinschaftErlaubnisAm  DateTime? // Datum der Einwilligung

  // Vereinsrollen (fuer Mitglieder OHNE User-Account, z.B. Kinder)
  vereinsRollen      String[]

  // Selbstverwaltung
  notfallKontakt     String?
  notfallTelefon     String?
  iban               String?

  attendances          Attendance[]
  teamMembers          TeamMember[]
  kasseBuchungen       KasseBuchung[]
  trikotVergaben       TrikotVergabe[]
  verletzungen         Verletzung[]
  entwicklungsboegen   Entwicklungsbogen[]
  aenderungsantraege   MemberAenderungsantrag[]
  warteliste           Warteliste[]
  familieMitgliedschaften FamilieMitglied[]
  ehrenamtMeldungen          EhrenamtMeldung[]
  festSchichtHelfer          FestSchichtHelfer[]
  einverstaendnisAntworten   EinverstaendnisAntwort[]
  dokumente                  MitgliedDokument[]

  @@index([tenantId])
  @@index([email])
}

enum MemberStatus {
  PENDING
  ACTIVE
  INACTIVE
  CANCELLED
}

enum Ermaessigung {
  KEINE
  STUDENT // Studentenausweis erforderlich
  SCHUELER // Schuelerausweis
  AZUBI // Ausbildungsnachweis
  RENTNER // Rentenausweis
  SCHWERBEHINDERT // Schwerbehindertenausweis
  EHRENAMT // Ehrenamtlich taetig
  FAMILIE // Familienermaessigung (ab 2. Mitglied)
  SOZIAL // Sozialpass / ALG-Bescheid
  SONSTIGE // Individuell vereinbart
}

// ==================== Aenderungsantraege (Mitglieder-Selbstverwaltung) ====================

model MemberAenderungsantrag {
  id             String            @id @default(cuid())
  tenantId       String
  memberId       String
  member         Member            @relation(fields: [memberId], references: [id], onDelete: Cascade)
  feld           String            // Welches Feld: phone, address, iban, notfallKontakt, notfallTelefon
  alterWert      String?           // Alter Wert
  neuerWert      String            // Neuer Wert
  status         AenderungsStatus  @default(PENDING)
  erstelltAm     DateTime          @default(now())
  bearbeitetAm   DateTime?
  bearbeitetVon  String?           // userId des Admins

  @@index([tenantId])
  @@index([memberId])
  @@index([status])
}

enum AenderungsStatus {
  PENDING
  GENEHMIGT
  ABGELEHNT
}

enum NachweisStatus {
  NICHT_ERFORDERLICH // Kein Nachweis noetig
  AUSSTEHEND // Nachweis fehlt noch
  EINGEREICHT // Nachweis hochgeladen, wartet auf Pruefung
  GENEHMIGT // Nachweis geprueft und genehmigt
  ABGELEHNT // Nachweis abgelehnt
  ABGELAUFEN // Nachweis ist abgelaufen (z.B. Semester vorbei)
}

// ==================== Beitragsklasse ====================

model Beitragsklasse {
  id             String   @id @default(cuid())
  tenantId       String
  name           String   // z.B. "Jugend Fussball", "Erwachsene Tennis"
  beschreibung   String?
  betrag         Float    // Monatsbetrag in EUR
  intervall      String   @default("MONATLICH") // MONATLICH, QUARTALSWEISE, HALBJAEHRLICH, JAEHRLICH
  sportarten     String[] // Fuer welche Sportarten gilt diese Klasse
  altersVon      Int?     // Ab Alter (null = kein Minimum)
  altersBis      Int?     // Bis Alter (null = kein Maximum)
  istAktiv       Boolean  @default(true)
  sortierung     Int      @default(0)
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@index([tenantId])
}

// ==================== Abteilung (z.B. Fussball, Handball) ====================

model Abteilung {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String // z.B. "Fussball", "Handball"
  sport        Sport
  leiterIds    String[] // UserIDs der Abteilungsleiter
  beschreibung String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  teams    Team[]
  umfragen Umfrage[]

  @@unique([tenantId, sport])
  @@index([tenantId])
}

// ==================== Mannschaft ====================

model Team {
  id          String     @id @default(cuid())
  name        String
  sport       Sport
  ageGroup    String
  trainerId   String?    // Optional: Trainer kann spaeter zugeordnet werden
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  abteilungId String?
  abteilung   Abteilung? @relation(fields: [abteilungId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  maxKader           Int?       // null = unbegrenzt

  events             Event[]
  messages           Message[]
  teamMembers        TeamMember[]
  hallenbelegungen   Hallenbelegung[]
  pinboardItems      PinboardItem[]
  kasse              TeamKasse?
  strafkatalog       Strafkatalog[]
  trikots            Trikot[]
  trainingsplaene    Trainingsplan[]
  aufstellungen      Aufstellung[]
  entwicklungsboegen Entwicklungsbogen[]
  umfragen           Umfrage[]
  aushaenge          Aushang[]
  warteliste         Warteliste[]
  ehrenamtAufgaben   EhrenamtAufgabe[]
  fotos              Foto[]
  saisonplaene       Saisonplan[]

  @@index([tenantId])
  @@index([abteilungId])
}

// ==================== Kader (Team-Mitglieder) ====================

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  rolle     String   @default("SPIELER")
  createdAt DateTime @default(now())

  @@unique([teamId, memberId])
  @@index([teamId])
  @@index([memberId])
}

// ==================== Warteliste ====================

model Warteliste {
  id               String            @id @default(cuid())
  teamId           String
  team             Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  mitgliedId       String
  member           Member            @relation(fields: [mitgliedId], references: [id])
  tenantId         String
  angemeldetAm     DateTime          @default(now())
  benachrichtigtAm DateTime?
  bestaetigtBis    DateTime?         // 48h Frist nach Einladung
  status           WartelistenStatus @default(WARTEND)

  @@unique([teamId, mitgliedId])
  @@index([teamId])
  @@index([tenantId])
}

enum WartelistenStatus {
  WARTEND
  EINGELADEN
  BESTAETIGT
  ABGELAUFEN
}

enum Sport {
  FUSSBALL
  HANDBALL
  BASKETBALL
  FOOTBALL
  TENNIS
  TURNEN
  SCHWIMMEN
  LEICHTATHLETIK
  VOLLEYBALL
  TISCHTENNIS
  BADMINTON
  HOCKEY
  RUGBY
  BASEBALL
  SOFTBALL
  EISHOCKEY
  WASSERBALL
  RINGEN
  JUDO
  KARATE
  TAEKWONDO
  BOXEN
  FECHTEN
  REITEN
  GOLF
  KLETTERN
  SKIFAHREN
  SNOWBOARD
  RADSPORT
  TRIATHLON
  RUDERN
  KANU
  SEGELN
  TANZEN
  YOGA
  FITNESS
  CROSSFIT
  WANDERN
  LAUFEN
  DART
  BILLARD
  SCHACH
  ESPORT
  CHEERLEADING
  AKROBATIK
  TRAMPOLINTURNEN
  RHYTHMISCHE_SPORTGYMNASTIK
  EISKUNSTLAUF
  BOGENSCHIESSEN
  SCHIESSEN
  ANGELN
  MOTORSPORT
  FLOORBALL
  LACROSSE
  CRICKET
  SQUASH
  KICKBOXEN
  MMA
  CAPOEIRA
  PARKOUR
  SKATEBOARD
  SURFEN
  TAUCHEN
  WASSERSKI
  GEWICHTHEBEN
  POWERLIFTING
  ROLLSPORT
  PETANQUE
  CURLING
  SONSTIGES
  CUSTOM // Fuer vom Verein selbst definierte Sportarten
}

// ==================== Eigene Sportarten (pro Verein) ====================

model CustomSportart {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String // z.B. "Unterwasser-Rugby", "Quidditch"
  beschreibung String?
  icon         String? // Optionales Icon/Emoji
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
}

// ==================== Veranstaltungen ====================

model Event {
  id             String    @id @default(cuid())
  title          String
  type           EventType
  date           DateTime
  endDate        DateTime?
  location       String
  hallName       String?
  hallAddress    String?
  untergrund     String?
  halleId        String?   // Verknuepfung zur Halle (automatische Belegung)
  teamId         String
  team           Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  notes          String?
  // Wiederkehrende Events
  recurrenceRule String? // z.B. "WEEKLY:DI,DO" oder "BIWEEKLY:MI"
  recurrenceEnd  DateTime? // Bis wann wiederholen
  parentEventId  String? // Referenz auf das Eltern-Event (Vorlage)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  lat           Float?
  lng           Float?
  attendances   Attendance[]
  reminders     Reminder[]
  comments      EventComment[]
  schnellTokens SchnellAnmeldungToken[]
  landingpage   EventLandingpage?
  spielbericht  Spielbericht?
  festSchichten     FestSchicht[]
  festEinkaeufe     FestEinkauf[]
  festKasse         FestKasse[]
  einverstaendnisse Einverstaendnis[]
  fotos             Foto[]

  @@index([tenantId])
  @@index([teamId])
  @@index([date])
}

// ==================== Event-Kommentare ====================

model EventComment {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  content   String
  createdAt DateTime @default(now())

  @@index([eventId])
}

enum EventType {
  TRAINING
  MATCH
  TOURNAMENT
  TRIP
  MEETING
  EVENT       // Allgemeine Veranstaltung (Vereinsfest, Jubilaeum, Halloween etc.)
  VOLUNTEER   // Helfereinsatz, Aufbau, Abbau
}

// ==================== Anwesenheit ====================

model Attendance {
  id         String           @id @default(cuid())
  eventId    String
  event      Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  memberId   String
  member     Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  status     AttendanceStatus @default(PENDING)
  reason     String?
  answeredAt DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([eventId, memberId])
  @@index([eventId])
  @@index([memberId])
}

enum AttendanceStatus {
  PENDING
  YES
  NO
  MAYBE
}

// ==================== Turnier ====================

model Tournament {
  id        String           @id @default(cuid())
  name      String
  sport     Sport
  format    TournamentFormat
  publicUrl String           @unique
  tenantId  String
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  isLive    Boolean          @default(false)
  qrCode    String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  matches     TournamentMatch[]
  landingpage TurnierLandingpage?

  @@index([tenantId])
  @@index([publicUrl])
}

enum TournamentFormat {
  GRUPPE
  KO
  SCHWEIZER
  KOMBINATION
}

model TournamentMatch {
  id           String      @id @default(cuid())
  tournamentId String
  tournament   Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team1        String
  team2        String
  score1       Int?
  score2       Int?
  time         DateTime?
  field        String?
  status       MatchStatus @default(GEPLANT)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([tournamentId])
}

enum MatchStatus {
  GEPLANT
  LAUFEND
  BEENDET
  ABGESAGT
}

// ==================== Formulare ====================

model FormTemplate {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  type      FormType
  fileUrl   String
  fields    Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissions FormSubmission[]

  @@index([tenantId])
}

enum FormType {
  MITGLIEDSANTRAG
  EINVERSTAENDNIS
  DATENSCHUTZ
  SONSTIGES
}

// ==================== Formular-Einreichungen (Online-Antraege) ====================

model FormSubmission {
  id               String           @id @default(cuid())
  tenantId         String
  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  templateId       String
  template         FormTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  eingereichtVon   String? // userId, falls angemeldet
  email            String // E-Mail des Antragstellers
  daten            Json // Ausgefuellte Felder als JSON
  signatureUrl     String? // Digitale Unterschrift als Data-URL
  signaturDatenUrl String? // Base64-Signaturdaten (data:image/png;base64,...)
  status           SubmissionStatus @default(EINGEREICHT)
  kommentar        String? // Interner Kommentar vom Admin
  archiviertePdf   String? // URL der archivierten PDF
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([tenantId])
  @@index([templateId])
  @@index([status])
}

enum SubmissionStatus {
  EINGEREICHT // Antrag gestellt
  IN_PRUEFUNG // Wird geprueft
  GENEHMIGT // Genehmigt → Mitglied wird angelegt
  ABGELEHNT // Abgelehnt
  ARCHIVIERT // Archiviert
}

// ==================== Dokumenten-Ablage ====================

model Dokument {
  id             String            @id @default(cuid())
  tenantId       String
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  beschreibung   String?
  dateiUrl       String // Pfad im S3/Storage
  dateiGroesse   Int // Groesse in Bytes
  dateiTyp       String // MIME-Type (application/pdf, image/png, etc.)
  kategorie      DokumentKategorie @default(SONSTIGES)
  ordner         String? // Optionaler Ordner-Pfad
  hochgeladenVon String // userId
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([tenantId])
  @@index([kategorie])
  @@index([ordner])
}

enum DokumentKategorie {
  MITGLIEDSANTRAG
  VERTRAG
  RECHNUNG
  PROTOKOLL
  TRAININGSPLAN
  SATZUNG
  DATENSCHUTZ
  SONSTIGES
}

// ==================== Erinnerungen ====================

model Reminder {
  id           String       @id @default(cuid())
  eventId      String
  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  type         ReminderType
  sentAt       DateTime?
  scheduledFor DateTime
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([eventId])
  @@index([scheduledFor])
}

enum ReminderType {
  H24
  H2
  CUSTOM
}

// ==================== Nachrichten ====================

model Message {
  id          String      @id @default(cuid())
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teamId      String?
  team        Team?       @relation(fields: [teamId], references: [id], onDelete: SetNull)
  senderId    String
  content     String
  type        MessageType
  isEmergency Boolean     @default(false)
  silentFrom  String?
  silentTo    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  reads     MessageRead[]
  reactions MessageReaction[]

  @@index([tenantId])
  @@index([teamId])
}

enum MessageType {
  BROADCAST
  ANNOUNCEMENT
  TEAM_CHAT
  QUESTION
  FAQ_ANSWER
}

model MessageRead {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  readAt    DateTime @default(now())

  @@unique([messageId, userId])
  @@index([messageId])
}

// ==================== Nachricht-Reaktionen ====================

model MessageReaction {
  id        String      @id @default(cuid())
  messageId String
  message   Message     @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  reaktion  ReaktionTyp
  createdAt DateTime    @default(now())

  @@unique([messageId, userId])
  @@index([messageId])
}

enum ReaktionTyp {
  GESEHEN
  JA
  NEIN
  VIELLEICHT
}

// ==================== Benachrichtigungs-Einstellungen ====================

model BenachrichtigungsEinstellung {
  id                    String   @id @default(cuid())
  userId                String   @unique
  pushAktiv             Boolean  @default(true)
  emailAktiv            Boolean  @default(true)
  stilleStundenVon      Int      @default(22)
  stilleStundenBis      Int      @default(7)
  notfallUeberschreiben Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
}

// ==================== FAQ ====================

model FAQ {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teamId    String?
  question  String
  answer    String
  useCount  Int      @default(0)
  embedding Json? // Float-Array fuer Similarity-Suche
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// ==================== Eltern-Fragen ====================

enum FrageStatus {
  OFFEN
  AUTOMATISCH_BEANTWORTET
  BEANTWORTET
}

model ElternFrage {
  id            String      @id @default(cuid())
  tenantId      String
  teamId        String?
  fragenderId   String // userId des Elternteils
  frage         String
  antwort       String?
  automatisch   Boolean     @default(false)
  status        FrageStatus @default(OFFEN)
  createdAt     DateTime    @default(now())
  beantwortetAm DateTime?

  @@index([tenantId])
  @@index([teamId])
  @@index([status])
}

// ==================== Schnell-Anmeldung per E-Mail-Link ====================

model SchnellAnmeldungToken {
  id         String   @id @default(cuid())
  token      String   @unique
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  memberId   String
  benutzt    Boolean  @default(false)
  gueltigBis DateTime
  createdAt  DateTime @default(now())

  @@index([token])
  @@index([eventId])
}

// ==================== Fahrtenborse ====================

model Fahrgemeinschaft {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  eventId   String?
  fahrerId  String // userId des Fahrers
  startort  String
  zielort   String
  abfahrt   DateTime
  plaetze   Int      @default(4)
  kommentar String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mitfahrer Mitfahrer[]

  @@index([tenantId])
  @@index([eventId])
}

model Mitfahrer {
  id                 String           @id @default(cuid())
  fahrgemeinschaftId String
  fahrgemeinschaft   Fahrgemeinschaft @relation(fields: [fahrgemeinschaftId], references: [id], onDelete: Cascade)
  userId             String
  createdAt          DateTime         @default(now())

  @@unique([fahrgemeinschaftId, userId])
  @@index([fahrgemeinschaftId])
}

// ==================== Schiedsrichter-Einteilung ====================

model SchiedsrichterEinteilung {
  id         String       @id @default(cuid())
  tenantId   String
  eventId    String
  memberId   String // Mitglied das als Schiedsrichter eingeteilt ist
  status     SchiriStatus @default(EINGETEILT)
  bestaetigt Boolean      @default(false)
  notiz      String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@unique([eventId, memberId])
  @@index([tenantId])
  @@index([eventId])
}

enum SchiriStatus {
  EINGETEILT
  BESTAETIGT
  ABGELEHNT
  ERSATZ
}

// ==================== Buchhaltung / SEPA ====================

model Rechnung {
  id           String         @id @default(cuid())
  tenantId     String
  memberId     String
  rechnungsNr  String
  betrag       Float
  beschreibung String
  faelligAm    DateTime
  bezahltAm    DateTime?
  status       RechnungStatus @default(OFFEN)
  sepaMandat   String? // SEPA-Mandatsreferenz
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([tenantId])
  @@index([memberId])
  @@index([status])
}

enum RechnungStatus {
  OFFEN
  BEZAHLT
  UEBERFAELLIG
  STORNIERT
}

model Beitrag {
  id        String   @id @default(cuid())
  tenantId  String
  name      String // z.B. "Jahresbeitrag Erwachsene"
  betrag    Float
  intervall String // MONATLICH, QUARTALSWEISE, JAEHRLICH
  sportart  String? // Optional: nur fuer bestimmte Sportart
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// ==================== Workflows (Einladungs-Pakete) ====================

model Workflow {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String // z.B. "Neues Mitglied Fussball"
  beschreibung String? // z.B. "Alle Unterlagen fuer neue Fussball-Mitglieder"
  templateIds  String[] // Welche Formulare gesendet werden
  sportarten   String[] // Vorbelegte Sportarten
  emailBetreff String? // Optionaler eigener E-Mail-Betreff
  emailText    String? // Optionaler eigener E-Mail-Text
  istAktiv     Boolean  @default(true)
  erstelltVon  String // userId des Erstellers (Admin/Vorstand)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
}

// ==================== Hallenbelegung ====================

model Halle {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  adresse       String?
  kapazitaet    Int?
  lat           Float?
  lng           Float?
  mapsUrl       String?
  parkplatzInfo String?
  zugangscode   String?
  untergruende  String[] @default([])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  belegungen Hallenbelegung[]

  @@index([tenantId])
}

model Hallenbelegung {
  id        String   @id @default(cuid())
  halleId   String
  halle     Halle    @relation(fields: [halleId], references: [id], onDelete: Cascade)
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  wochentag    String   // MO, DI, MI, DO, FR, SA, SO
  von          String   // "18:00"
  bis          String   // "20:00"
  notiz        String?
  wiederholung String   @default("WOECHENTLICH") // WOECHENTLICH, TAEGLICH, EINMALIG, ALLE_2_WOCHEN
  gueltigVon   DateTime? // Ab wann gilt die Belegung (null = sofort)
  gueltigBis   DateTime? // Bis wann (null = unbegrenzt, z.B. Saisonende)
  einmalDatum  DateTime? // Nur bei EINMALIG: konkretes Datum
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([halleId])
  @@index([teamId])
}

// ==================== Sponsoren ====================

model Sponsor {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  logoUrl         String?
  webseite        String?
  beschreibung    String?
  kontaktName     String?
  kontaktEmail    String?
  istAktiv        Boolean   @default(true)
  // Sponsoren-Portal (Magic Link Login)
  loginEmail      String?   @unique // Sponsor login E-Mail
  loginToken      String?            // Magic Link Token
  tokenGueltigBis DateTime?
  // Paket-Informationen
  paketName       String?   // z.B. "Gold-Sponsor", "Hauptsponsor"
  betrag          Float?    // Jahresbetrag in EUR
  vertragStart    DateTime?
  vertragEnde     DateTime?
  sichtbarkeit    String[]  @default([]) // z.B. ["Homepage", "Trikots", "Events", "Bandenwerbung"]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId])
  @@index([loginToken])
}

// ==================== E-Mail-Einstellungen (pro Benutzer) ====================

model EmailEinstellungen {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  smtpHost      String
  smtpPort      Int      @default(587)
  smtpUser      String
  smtpPass      String // Base64-kodiert gespeichert (TODO: richtige Verschluesselung mit AES-256)
  absenderEmail String // z.B. trainer.mueller@fcmusterstadt.de
  absenderName  String // z.B. "Thomas Mueller - FC Musterstadt"
  signatur      String? // HTML-Signatur fuer E-Mails
  istAktiv      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

// ==================== E-Mail Posteingang ====================

model EmailPosteingang {
  id           String   @id @default(cuid())
  tenantId     String
  empfaengerId String? // userId des Empfaengers (null = Vereins-Postfach)
  von          String // Absender E-Mail
  vonName      String? // Absender Name
  an           String // Empfaenger E-Mail
  betreff      String
  inhalt       String // HTML oder Plain-Text
  inhaltText   String? // Plain-Text Version
  gelesen      Boolean  @default(false)
  istWichtig   Boolean  @default(false)
  ordner       String   @default("POSTEINGANG")
  anhaenge     String[] // URLs zu Anhaengen
  messageId    String? // Original Message-ID Header
  inReplyTo    String? // Referenz auf vorherige Nachricht
  empfangenAm  DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([tenantId])
  @@index([empfaengerId])
  @@index([ordner])
  @@index([empfangenAm])
}

enum EmailOrdner {
  POSTEINGANG
  GESENDET
  ENTWUERFE
  ARCHIV
  PAPIERKORB
}

model EmailEntwurf {
  id         String   @id @default(cuid())
  tenantId   String
  absenderId String // userId
  an         String[] // Empfaenger-Adressen
  betreff    String?
  inhalt     String?
  anhaenge   String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
  @@index([absenderId])
}

// ==================== Profilbild ====================

model Profilbild {
  id        String   @id @default(cuid())
  userId    String   @unique
  bildUrl   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ==================== Vereinshomepage ====================

model Homepage {
  id               String   @id @default(cuid())
  tenantId         String   @unique
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  istAktiv         Boolean  @default(false)
  subdomain        String?  @unique // z.B. "fckunchen" -> fckunchen.vereinbase.de
  customDomain     String?  @unique // z.B. "www.fc-kunchen.de"
  // Inhalte
  heroTitel        String? // z.B. "Willkommen beim FC Kunchen"
  heroUntertitel   String? // z.B. "Seit 1920 - Ihr Sportverein im Filstal"
  heroBildUrl      String?
  ueberUns         String? // Freitext HTML/Markdown
  gruendungsjahr   Int?
  mitgliederAnzahl Int? // Wird automatisch berechnet
  kontaktEmail     String?
  kontaktTelefon   String?
  kontaktAdresse   String?
  oeffnungszeiten  String?
  impressum        String?
  datenschutz      String?
  socialFacebook   String?
  socialInstagram  String?
  socialYoutube    String?
  // SEO
  seoTitel         String?
  seoBeschreibung  String?
  // Design
  headerBildUrl    String?
  footerText       String?
  customCss        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sektionen HomepageSektion[]

  @@index([tenantId])
  @@index([subdomain])
}

model HomepageSektion {
  id          String      @id @default(cuid())
  homepageId  String
  homepage    Homepage    @relation(fields: [homepageId], references: [id], onDelete: Cascade)
  typ         SektionsTyp
  titel       String?
  inhalt      String? // HTML/Markdown Inhalt
  bildUrl     String?
  reihenfolge Int         @default(0)
  istSichtbar Boolean     @default(true)
  daten       Json? // Zusaetzliche strukturierte Daten
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([homepageId])
  @@index([reihenfolge])
}

enum SektionsTyp {
  HERO // Grosses Header-Bild mit Titel
  UEBER_UNS // Ueber den Verein
  ABTEILUNGEN // Sportarten/Abteilungen Uebersicht
  MANNSCHAFTEN // Teams anzeigen
  TERMINE // Naechste Events/Spiele
  NEUIGKEITEN // Aktuelles/News
  KONTAKT // Kontaktformular/Infos
  SPONSOREN // Sponsor-Logos
  GALERIE // Bildergalerie
  MITGLIED_WERDEN // CTA zum Beitreten
  FREITEXT // Freier HTML-Inhalt
  TURNIER // Turnier Landing-Page Sektion
}

// ==================== Turnier-Landingpage ====================

model TurnierLandingpage {
  id              String     @id @default(cuid())
  tournamentId    String     @unique
  tournament      Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  istAktiv        Boolean    @default(true)
  slug            String     @unique // z.B. "hallencup-2026"
  // Inhalte
  titel           String
  beschreibung    String? // HTML fuer Werbezwecke
  bannerBildUrl   String?
  ort             String?
  datum           String? // Freitext: "14.-15. Juni 2026"
  teilnahmeInfo   String? // Wie teilnehmen
  preise          String? // Preise/Pokale
  sponsoren       String[] // Sponsor-Namen
  sponsorLogos    String[] // Sponsor-Logo-URLs
  kontaktEmail    String?
  // SEO
  seoTitel        String?
  seoBeschreibung String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([slug])
}

// ==================== Event-Landingpages ====================

model EventLandingpage {
  id              String   @id @default(cuid())
  eventId         String   @unique
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  istAktiv        Boolean  @default(true)
  slug            String   @unique // z.B. "sommercamp-2026"
  // Inhalte
  titel           String
  beschreibung    String? // HTML fuer Werbezwecke
  bannerBildUrl   String?
  ort             String?
  datum           String? // Freitext: "14.-15. Juni 2026"
  zeitplan        String? // Ablauf/Zeitplan
  anfahrt         String? // Anfahrtsbeschreibung
  kontaktEmail    String?
  kontaktTelefon  String?
  // SEO
  seoTitel        String?
  seoBeschreibung String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([slug])
}

// ==================== Einladungen ====================

model Einladung {
  id            String          @id @default(cuid())
  tenantId      String
  token         String          @unique
  vorname       String
  nachname      String
  email         String
  templateIds   String[] // Mehrere Formulare (Antrag, EWE, Datenschutz)
  sportarten    String[] // Sportarten fuer die Anmeldung
  geburtsdatum  String? // Optionales Geburtsdatum
  workflowId    String? // Welcher Workflow verwendet wurde
  status        EinladungStatus @default(GESENDET)
  eingeladenVon String // userId des Trainers/Vorstands
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([token])
  @@index([tenantId])
}

enum EinladungStatus {
  GESENDET // E-Mail verschickt
  GEOEFFNET // Link wurde geklickt
  AUSGEFUELLT // Formular wurde ausgefuellt
  ABGELAUFEN // Token abgelaufen (30 Tage)
}

// ==================== Pinboard (Team-Pinnwand) ====================

model PinboardItem {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teamId       String
  team         Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  titel        String
  inhalt       String
  icon         String   @default("info")
  istAngepinnt Boolean  @default(false)
  erstelltVon  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([teamId])
  @@index([tenantId])
}

// ==================== Spielbericht ====================

model Spielbericht {
  id              String   @id @default(cuid())
  eventId         String   @unique
  tenantId        String
  ergebnis        String
  gegner          String
  aufstellung     Json?
  torschuetzen    Json?
  assists         Json?
  gelbeKarten     Json?
  roteKarten      Json?
  trainerNotiz    String?
  kiText          String?
  veroeffentlicht Boolean  @default(false)
  erstelltAm      DateTime @default(now())
  aktualisiertAm  DateTime @updatedAt
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ==================== Mannschaftskasse ====================

model TeamKasse {
  id        String         @id @default(cuid())
  teamId    String         @unique
  stand     Float          @default(0)
  team      Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  buchungen KasseBuchung[]
}

model KasseBuchung {
  id          String      @id @default(cuid())
  kasseId     String
  memberId    String
  betrag      Float
  grund       String
  typ         BuchungsTyp
  erstelltVon String
  erstelltAm  DateTime    @default(now())
  kasse       TeamKasse   @relation(fields: [kasseId], references: [id], onDelete: Cascade)
  member      Member      @relation(fields: [memberId], references: [id])

  @@index([kasseId])
  @@index([memberId])
}

enum BuchungsTyp {
  STRAFE
  EINZAHLUNG
  AUSGABE
}

model Strafkatalog {
  id     String @id @default(cuid())
  teamId String
  name   String
  betrag Float
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

// ==================== Trikotverwaltung ====================

model Trikot {
  id       String          @id @default(cuid())
  teamId   String
  nummer   Int
  groesse  String?
  farbe    String?
  zustand  String?
  vergaben TrikotVergabe[]
  team     Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, nummer, farbe])
}

model TrikotVergabe {
  id         String    @id @default(cuid())
  trikotId   String
  memberId   String
  vergabenAm DateTime  @default(now())
  zurueckAm  DateTime?
  notiz      String?
  trikot     Trikot    @relation(fields: [trikotId], references: [id], onDelete: Cascade)
  member     Member    @relation(fields: [memberId], references: [id])
}

// ==================== Wetter-Cache (Open-Meteo) ====================

model WetterCache {
  id           String   @id @default(cuid())
  lat          Float
  lng          Float
  datum        DateTime
  temperatur   Float?
  regen        Float?
  windkmh      Float?
  wettercode   Int?
  beschreibung String?
  geladenAm    DateTime @default(now())

  @@unique([lat, lng, datum])
}

// ==================== Ressourcen & Platzbuchung ====================

model Ressource {
  id           String    @id @default(cuid())
  tenantId     String
  name         String
  typ          String
  beschreibung String?
  bildUrl      String?
  maxPersonen  Int?
  aktiv        Boolean   @default(true)
  buchungen    Buchung[]
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Buchung {
  id          String        @id @default(cuid())
  ressourceId String
  tenantId    String
  bucherId    String
  titel       String
  start       DateTime
  ende        DateTime
  notiz       String?
  status      BuchungStatus @default(BESTAETIGT)
  erstelltAm  DateTime      @default(now())
  ressource   Ressource     @relation(fields: [ressourceId], references: [id], onDelete: Cascade)
  bucher      User          @relation(fields: [bucherId], references: [id])

  @@index([ressourceId])
  @@index([tenantId])
}

enum BuchungStatus {
  ANFRAGE
  BESTAETIGT
  ABGELEHNT
  STORNIERT
}

// ==================== KI-Trainingsplaene ====================

model Trainingsplan {
  id         String   @id @default(cuid())
  teamId     String
  tenantId   String
  titel      String
  parameter  Json
  inhalt     Json
  erstelltAm DateTime @default(now())
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([tenantId])
}

// ==================== Spieler-Entwicklungsbogen ====================

model Entwicklungsbogen {
  id                 String   @id @default(cuid())
  memberId           String
  teamId             String
  tenantId           String
  erstelltVon        String
  datum              DateTime @default(now())
  saison             String
  ball               Int?
  passen             Int?
  schuss             Int?
  zweikampf          Int?
  kopfball           Int?
  spielverstaendnis  Int?
  positionsspiel     Int?
  defensivverhalten  Int?
  schnelligkeit      Int?
  ausdauer           Int?
  sprungkraft        Int?
  teamgeist          Int?
  einstellung        Int?
  coaching           Int?
  staerken           String?
  entwicklungsfelder String?
  ziele              String?
  trainerEmpfehlung  String?
  member             Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  team               Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([teamId])
}

// ==================== Aufstellung (Lineup Planner) ====================

model Aufstellung {
  id         String   @id @default(cuid())
  teamId     String
  tenantId   String
  eventId    String?
  name       String
  formation  String
  positionen Json
  publicUrl  String?  @unique
  erstelltAm DateTime @default(now())
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

// ==================== Verletzungsprotokoll ====================

model Verletzung {
  id             String     @id @default(cuid())
  memberId       String
  tenantId       String
  art            String
  koerperteil    String
  datum          DateTime   @default(now())
  pauseVoraus    Int?
  zurueckAm      DateTime?
  notiz          String?
  status         RehaStatus @default(VERLETZT)
  erstelltVon    String
  erstelltAm     DateTime   @default(now())
  aktualisiertAm DateTime   @updatedAt
  member         Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  tenant         Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([tenantId])
}

enum RehaStatus {
  VERLETZT
  REHA
  BEOBACHTEN
  FIT
}

// ==================== Empfehlungsprogramm (Referral) ====================

model Referral {
  id           String    @id @default(cuid())
  referrerId   String    @unique
  code         String    @unique
  genutzteVon  String[]
  freiMonate   Int       @default(0)
  ausgezahltAm DateTime?
  erstelltAm   DateTime  @default(now())
  referrer     Tenant    @relation(fields: [referrerId], references: [id], onDelete: Cascade)
}

// ==================== Web-Push-Abonnements ====================

model WebPushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ==================== Umfragen (Doodle-Ersatz / Quick Polls) ====================

model Umfrage {
  id           String           @id @default(cuid())
  tenantId     String
  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teamId       String?
  team         Team?            @relation(fields: [teamId], references: [id])
  abteilungId  String?
  abteilung    Abteilung?       @relation(fields: [abteilungId], references: [id])
  frage        String
  optionen     String[]
  endetAm      DateTime?
  erstelltVon  String
  erstelltAm   DateTime         @default(now())
  antworten    UmfrageAntwort[]

  @@index([tenantId])
  @@index([teamId])
  @@index([abteilungId])
}

model UmfrageAntwort {
  id            String   @id @default(cuid())
  umfrageId     String
  umfrage       Umfrage  @relation(fields: [umfrageId], references: [id], onDelete: Cascade)
  mitgliedId    String?
  mitgliedName  String?
  option        String
  beantwortetAm DateTime @default(now())

  @@index([umfrageId])
}

// ==================== Schwarzes Brett (Aushaenge) ====================

model Aushang {
  id           String           @id @default(cuid())
  tenantId     String
  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teamId       String?
  team         Team?            @relation(fields: [teamId], references: [id], onDelete: SetNull)
  titel        String
  inhalt       String           // HTML content
  kategorie    AushangKategorie
  bildUrl      String?
  ablaufDatum  DateTime?        // Auto-hide after this date
  erstelltVon  String           // userId
  erstelltAm   DateTime         @default(now())

  @@index([tenantId])
  @@index([teamId])
}

enum AushangKategorie {
  INFO
  WICHTIG
  TRAINING
  AUSFALL
}

// ==================== Familie ====================

model Familie {
  id          String            @id @default(cuid())
  tenantId    String
  name        String            // z.B. "Familie Mueller" (auto-generated from first member's last name)
  mitglieder  FamilieMitglied[]
  createdAt   DateTime          @default(now())

  @@index([tenantId])
}

model FamilieMitglied {
  id          String         @id @default(cuid())
  familieId   String
  familie     Familie        @relation(fields: [familieId], references: [id], onDelete: Cascade)
  memberId    String?        // linked Member (child/playing member)
  member      Member?        @relation(fields: [memberId], references: [id])
  userId      String?        // linked User account (parent/guardian)
  user        User?          @relation(fields: [userId], references: [id])
  rolle       FamilienRolle
  createdAt   DateTime       @default(now())

  @@index([familieId])
  @@index([memberId])
  @@index([userId])
}

enum FamilienRolle {
  KIND                       // Child (linked to Member)
  MUTTER                     // Mother (linked to User)
  VATER                      // Father (linked to User)
  ERZIEHUNGSBERECHTIGTER     // Guardian
  PARTNER                    // Partner/Spouse
}

// ==================== Marktplatz (vereinsuebergreifend) ====================

model MarktplatzInserat {
  id              String              @id @default(cuid())
  tenantId        String
  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  erstelltVon     String              // userId
  kategorie       InseratKategorie
  typ             InseratTyp          // ANGEBOT or GESUCH
  titel           String
  beschreibung    String
  sportart        String?             // z.B. FUSSBALL, HANDBALL
  bildUrl         String?
  preis           Float?              // null = kostenlos/VB
  plz             String              // Fuer Standort-Filterung
  ort             String
  kontaktEmail    String
  kontaktTelefon  String?
  // Fuer Trainer/Spiel-spezifisch
  datum           DateTime?           // Wann wird der Trainer/Gegner gebraucht
  altersgruppe    String?             // z.B. U12, Senioren
  // Status
  aktiv           Boolean             @default(true)
  ablaufDatum     DateTime?           // Auto-Deaktivierung
  erstelltAm      DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  bewerbungen     MarktplatzBewerbung[]

  @@index([tenantId])
  @@index([kategorie])
  @@index([plz])
  @@index([aktiv])
}

model MarktplatzBewerbung {
  id                String              @id @default(cuid())
  inseratId         String
  inserat           MarktplatzInserat   @relation(fields: [inseratId], references: [id], onDelete: Cascade)
  bewerberTenantId  String
  bewerberUserId    String
  bewerberName      String              // Vereinsname
  nachricht         String
  kontaktEmail      String
  status            BewerbungStatus     @default(NEU)
  erstelltAm        DateTime            @default(now())

  @@index([inseratId])
  @@index([bewerberTenantId])
}

enum InseratKategorie {
  SPORTGERAETE        // Baelle, Tore, Netze, Matten
  TRIKOTS             // Trikots, Schuhe, Ausruestung
  TRAINER             // Trainer gesucht/angeboten
  FREUNDSCHAFTSSPIEL  // Gegner fuer Freundschaftsspiel
  TURNIER             // Teams fuer Turnier gesucht
  SCHIEDSRICHTER      // SR gesucht/angeboten
  SONSTIGES           // Alles andere
}

enum InseratTyp {
  ANGEBOT     // Wir bieten an
  GESUCH      // Wir suchen
}

enum BewerbungStatus {
  NEU
  KONTAKTIERT
  ABGELEHNT
  ERLEDIGT
}

// ==================== Vertraege & NDAs (Plattform-Level) ====================

model Vertrag {
  id            String             @id @default(cuid())
  titel         String
  inhalt        String
  version       Int                @default(1)
  erstelltVon   String
  erstelltAm    DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  einladungen   VertragEinladung[]
}

model VertragEinladung {
  id                String    @id @default(cuid())
  vertragId         String
  vertrag           Vertrag   @relation(fields: [vertragId], references: [id], onDelete: Cascade)
  email             String
  name              String
  token             String    @unique
  unterschriebenAm  DateTime?
  unterschriftDaten String?
  ipAdresse         String?
  erstelltAm        DateTime  @default(now())

  @@index([vertragId])
  @@index([token])
}

// ==================== Ehrenamt (Helfer-Aufgaben + Uebungsleiterpauschale) ====================

model EhrenamtAufgabe {
  id            String         @id @default(cuid())
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teamId        String?
  team          Team?          @relation(fields: [teamId], references: [id], onDelete: SetNull)
  titel         String
  beschreibung  String?
  datum         DateTime?
  frist         DateTime?         // Deadline fuer Helfer-Anmeldung
  maxHelfer     Int?              // null = unbegrenzt
  status        AufgabenStatus    @default(OFFEN)
  erstelltVon   String
  erstelltAm    DateTime          @default(now())
  meldungen     EhrenamtMeldung[]

  @@index([tenantId])
  @@index([status])
}

model EhrenamtMeldung {
  id          String              @id @default(cuid())
  aufgabeId   String
  aufgabe     EhrenamtAufgabe     @relation(fields: [aufgabeId], references: [id], onDelete: Cascade)
  mitgliedId  String
  member      Member              @relation(fields: [mitgliedId], references: [id])
  status      MeldungStatus       @default(ANGEMELDET)
  erstelltAm  DateTime            @default(now())

  @@unique([aufgabeId, mitgliedId])
  @@index([aufgabeId])
}

model UebungsleiterStunden {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String
  datum        DateTime
  stunden      Float
  beschreibung String?
  erstelltAm   DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([datum])
}

enum AufgabenStatus {
  OFFEN
  BESETZT
  ABGESCHLOSSEN
  ABGESAGT
}

enum MeldungStatus {
  ANGEMELDET
  BESTAETIGT
  ABGELEHNT
}

// ==================== Audit-Log (Superadmin) ====================

model AuditLog {
  id          String   @id @default(cuid())
  aktion      String   // z.B. "VEREIN_GESPERRT", "PLAN_GEAENDERT", "IMPERSONATION", "KI_TOGGLE"
  details     String?  // JSON-String mit Details
  userId      String   // Wer hat die Aktion durchgefuehrt
  userEmail   String   // Fuer Anzeige
  tenantId    String?  // Welcher Verein betroffen (null fuer Plattform-Aktionen)
  tenantName  String?  // Fuer Anzeige
  ipAdresse   String?
  erstelltAm  DateTime @default(now())

  @@index([erstelltAm])
  @@index([userId])
  @@index([aktion])
}

// ==================== Vereinsfest-Planer ====================

model FestSchicht {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tenantId    String
  name        String           // z.B. "Theke 14-17 Uhr", "Grill 12-18 Uhr", "Aufbau 10 Uhr"
  startZeit   String?          // z.B. "14:00"
  endZeit     String?          // z.B. "17:00"
  maxHelfer   Int              @default(3)
  helfer      FestSchichtHelfer[]

  @@index([eventId])
  @@index([tenantId])
}

model FestSchichtHelfer {
  id          String   @id @default(cuid())
  schichtId   String
  schicht     FestSchicht @relation(fields: [schichtId], references: [id], onDelete: Cascade)
  mitgliedId  String
  member      Member   @relation(fields: [mitgliedId], references: [id])
  erstelltAm  DateTime @default(now())

  @@unique([schichtId, mitgliedId])
  @@index([schichtId])
}

model FestEinkauf {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tenantId    String
  artikel     String
  menge       String?           // z.B. "5 Kisten", "20 Stueck"
  kauftEin    String?           // Name der Person
  erledigt    Boolean  @default(false)
  erstelltAm  DateTime @default(now())

  @@index([eventId])
}

model FestKasse {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tenantId    String
  typ         FestKassenTyp
  betrag      Float
  beschreibung String
  erstelltAm  DateTime @default(now())

  @@index([eventId])
}

enum FestKassenTyp {
  EINNAHME
  AUSGABE
}

// ==================== Einverstaendniserklaerung (Eltern-Einverstaendnis) ====================

model Einverstaendnis {
  id            String   @id @default(cuid())
  tenantId      String
  eventId       String
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  titel         String           // z.B. "Einverstaendniserklaerung Ausflug Europapark"
  inhalt        String           // Text der Erklaerung
  erstelltVon   String
  erstelltAm    DateTime @default(now())
  antworten     EinverstaendnisAntwort[]

  @@index([tenantId])
  @@index([eventId])
}

model EinverstaendnisAntwort {
  id                  String   @id @default(cuid())
  einverstaendnisId   String
  einverstaendnis     Einverstaendnis @relation(fields: [einverstaendnisId], references: [id], onDelete: Cascade)
  mitgliedId          String
  member              Member   @relation(fields: [mitgliedId], references: [id])
  elternName          String           // Name des Elternteils das unterschrieben hat
  zugestimmt          Boolean
  unterschrift        String?          // Digitale Unterschrift Text
  ipAdresse           String?
  beantwortetAm       DateTime @default(now())

  @@unique([einverstaendnisId, mitgliedId])
  @@index([einverstaendnisId])
}

// ==================== Foto-Galerie ====================

model Foto {
  id              String   @id @default(cuid())
  tenantId        String
  teamId          String?
  team            Team?    @relation(fields: [teamId], references: [id])
  eventId         String?
  event           Event?   @relation(fields: [eventId], references: [id])
  url             String           // Bild-URL (hochgeladen)
  thumbnail       String?          // Thumbnail-URL
  beschreibung    String?
  hochgeladenVon  String           // userId
  erstelltAm      DateTime @default(now())

  @@index([tenantId])
  @@index([teamId])
  @@index([eventId])
}

// ==================== Vereins-Wiki ====================

model WikiSeite {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  titel         String
  inhalt        String           // HTML/Markdown content
  kategorie     String?          // z.B. "Halle", "Kontakte", "Ablaeufe"
  erstelltVon   String
  bearbeitetVon String?
  erstelltAm    DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([kategorie])
}

// ==================== Saisonplanung ====================

model Saisonplan {
  id          String        @id @default(cuid())
  tenantId    String
  teamId      String
  team        Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  saison      String                 // z.B. "2025/2026"
  startDatum  DateTime
  endDatum    DateTime
  phasen      SaisonPhase[]
  erstelltVon String
  erstelltAm  DateTime      @default(now())

  @@index([tenantId])
  @@index([teamId])
}

model SaisonPhase {
  id              String     @id @default(cuid())
  saisonplanId    String
  saisonplan      Saisonplan @relation(fields: [saisonplanId], references: [id], onDelete: Cascade)
  name            String              // z.B. "Vorbereitung", "Hinrunde", "Winterpause"
  startDatum      DateTime
  endDatum        DateTime
  schwerpunkt     String?             // z.B. "Kondition", "Taktik", "Spielpraxis"
  farbe           String?             // Hex color for timeline
  notizen         String?
  reihenfolge     Int        @default(0)

  @@index([saisonplanId])
}

// ==================== Trainer-Lizenzen ====================

model TrainerLizenz {
  id              String    @id @default(cuid())
  tenantId        String
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bezeichnung     String              // z.B. "C-Lizenz Fussball", "Uebungsleiter-C"
  ausstellerVerband String?           // z.B. "WFV", "DOSB"
  lizenznummer    String?
  erhaltenAm      DateTime
  gueltigBis      DateTime?           // null = unbefristet
  dokumentUrl     String?             // Upload der Lizenz-Urkunde
  notizen         String?
  erstelltAm      DateTime  @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([gueltigBis])
}

// ==================== Vereins-Crowdfunding ====================

model FundingProjekt {
  id              String        @id @default(cuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  titel           String
  beschreibung    String
  bildUrl         String?
  zielBetrag      Float
  aktuellerBetrag Float         @default(0)
  laufzeitBis     DateTime
  sichtbarkeit    String        @default("MITGLIEDER") // MITGLIEDER or OEFFENTLICH
  status          FundingStatus @default(AKTIV)
  erstelltVon     String
  erstelltAm      DateTime      @default(now())
  spenden         FundingSpende[]

  @@index([tenantId])
  @@index([status])
}

model FundingSpende {
  id            String         @id @default(cuid())
  projektId     String
  projekt       FundingProjekt @relation(fields: [projektId], references: [id], onDelete: Cascade)
  betrag        Float
  spenderName   String?        // null = anonym
  spenderEmail  String?
  anonym        Boolean        @default(false)
  nachricht     String?
  erstelltAm    DateTime       @default(now())

  @@index([projektId])
}

enum FundingStatus {
  AKTIV
  ERREICHT
  ABGELAUFEN
  GESCHLOSSEN
}

// ==================== Mitglied-Dokumente (Papierantraege, Scans) ====================

model MitgliedDokument {
  id               String                  @id @default(cuid())
  tenantId         String
  memberId         String
  member           Member                  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  name             String                  // z.B. "Mitgliedsantrag 2019", "Beitrittserklaerung"
  beschreibung     String?
  dateiUrl         String                  // /uploads/mitglied-dokumente/...
  dateiGroesse     Int                     // Bytes
  dateiTyp         String                  // MIME: application/pdf, image/jpeg, image/png
  kategorie        MitgliedDokumentTyp     @default(MITGLIEDSANTRAG)
  istFamilienantrag Boolean               @default(false) // Wenn true: auch fuer Familienmitglieder sichtbar
  hochgeladenVon   String                  // userId des Uploaders
  erstelltAm       DateTime               @default(now())

  @@index([tenantId])
  @@index([memberId])
}

enum MitgliedDokumentTyp {
  MITGLIEDSANTRAG
  BEITRITTSERKLAERUNG
  KUENDIGUNG
  EINVERSTAENDNIS
  AENDERUNGSANTRAG
  SONSTIGES
}

// ==================== Kooperationspartner (Plattform-Level, Superadmin) ====================

model Kooperationspartner {
  id               String              @id @default(cuid())
  name             String
  logoUrl          String?
  webseite         String?
  beschreibung     String?
  kategorie        PartnerKategorie
  kontaktEmail     String?
  kontaktTelefon   String?
  provisionProzent Float?              // Provision fuer Vereinbase in Prozent
  rabattProzent    Float?              // Rabatt fuer Vereine in Prozent
  rabattCode       String?             // Rabatt-Code fuer Bestellungen
  istAktiv         Boolean             @default(true)
  prioritaet       Int                 @default(0) // Sortierung (hoeher = weiter oben)
  erstelltAm       DateTime            @default(now())
  aktualisiertAm   DateTime            @updatedAt
}

enum PartnerKategorie {
  DRUCKEREI          // Trikot-/Bannerdruck
  AUSRUESTER         // Sportbekleidung, Baelle, etc.
  SPORTGERAETE       // Tore, Netze, Trainingsgeraete
  CATERING           // Vereinsfest, Turniere
  VERSICHERUNG       // Sportversicherungen
  MEDIEN             // Fotografie, Video, Social Media
  IT_DIENSTLEISTER   // Webseite, Hosting
  REISEN             // Trainingslager, Mannschaftsfahrten
  SONSTIGES
}

// ==================== Vereins-Partner/Dienstleister (Tenant-Level) ====================

model VereinsPartner {
  id               String              @id @default(cuid())
  tenantId         String
  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String
  logoUrl          String?
  webseite         String?
  beschreibung     String?
  kategorie        PartnerKategorie
  kontaktName      String?
  kontaktEmail     String?
  kontaktTelefon   String?
  notizen          String?             // Interne Notizen (z.B. "hat 2024 Bambini-Trikots gemacht")
  istAktiv         Boolean             @default(true)
  auftraege        VereinsPartnerAuftrag[]
  erstelltAm       DateTime            @default(now())
  aktualisiertAm   DateTime            @updatedAt

  @@index([tenantId])
  @@index([kategorie])
}

model VereinsPartnerAuftrag {
  id               String              @id @default(cuid())
  tenantId         String
  partnerId        String
  partner          VereinsPartner      @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  teamId           String?             // Fuer welches Team (optional)
  beschreibung     String              // z.B. "50 Trikots Bambini bedruckt"
  betrag           Float?              // Kosten in EUR
  datum            DateTime            @default(now())
  status           AuftragStatus       @default(OFFEN)
  erstelltVon      String              // userId
  erstelltAm       DateTime            @default(now())

  @@index([tenantId])
  @@index([partnerId])
}

enum AuftragStatus {
  OFFEN
  IN_BEARBEITUNG
  ABGESCHLOSSEN
  STORNIERT
}
