generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== Verein (Tenant) ====================

model Tenant {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  logo         String?
  primaryColor String   @default("#1a56db")
  plan         Plan     @default(STARTER)
  domain       String?
  kiProvider   String   @default("anthropic")
  kiApiKey     String?
  kiModell     String?
  // Vereinsdaten (Pflicht fuer Impressum/Rechtliches)
  vereinsNr          String?  // Vereinsregisternummer (z.B. VR 12345)
  amtsgericht        String?  // Zustaendiges Amtsgericht
  gruendungsjahr     Int?
  anschrift          String?  // Vereinsadresse
  plz                String?
  ort                String?
  bundesland         String?
  telefon            String?
  email              String?  // Offizielle Vereins-E-Mail
  webseite           String?
  // Vorstand / Vertretungsberechtigte
  vorstand1Name      String?  // 1. Vorsitzender
  vorstand1Funktion  String?  // z.B. "1. Vorsitzender"
  vorstand2Name      String?  // 2. Vorsitzender
  vorstand2Funktion  String?
  kassenwart         String?
  schriftfuehrer     String?
  jugendwart         String?
  // Rechtliches
  satzungUrl         String?  // Hochgeladene Satzung (PDF)
  satzungDatum       DateTime? // Datum der aktuellen Satzung
  impressum          String?  // Freitext Impressum (HTML)
  datenschutzUrl     String?  // Datenschutzerklaerung (PDF oder URL)
  datenschutzText    String?  // Freitext Datenschutz (HTML)
  // Versicherungen
  haftpflichtVersicherung    String?  // Vereinshaftpflicht Anbieter
  haftpflichtPoliceNr        String?  // Policennummer
  haftpflichtGueltigBis      DateTime?
  unfallVersicherung         String?  // Sportlunfallversicherung
  unfallPoliceNr             String?
  unfallGueltigBis           DateTime?
  gewaehrleistungsVersicherung String? // D&O / Vermoegens­schaden­haftpflicht
  // Finanzen
  steuernummer       String?  // Steuernummer
  finanzamt          String?  // Zustaendiges Finanzamt
  gemeinnuetzigBis   DateTime? // Gemeinnuetzigkeitsbescheid gueltig bis
  gemeinnuetzigUrl   String?  // Freistellungsbescheid (PDF)
  iban               String?  // Vereins-IBAN
  bic                String?
  bankName           String?
  // SMTP (globaler Vereins-Mailserver)
  smtpHost           String?
  smtpPort           Int?     @default(587)
  smtpUser           String?
  smtpPass           String?  // Base64-kodiert
  smtpAbsenderEmail  String?  // z.B. info@fckunchen.de
  smtpAbsenderName   String?  // z.B. "FC Kunchen 1920 e.V."
  // Sportverband-Mitgliedschaften
  landessportbund    String?  // z.B. "WLSB - Wuerttembergischer LSB"
  sportverband       String?  // z.B. "WFV - Wuerttembergischer FV"
  verbandsMitgliedsNr String? // Mitgliedsnummer beim Verband
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users              User[]
  abteilungen        Abteilung[]
  teams              Team[]
  events             Event[]
  tournaments        Tournament[]
  members            Member[]
  formTemplates      FormTemplate[]
  formSubmissions    FormSubmission[]
  messages           Message[]
  faqs               FAQ[]
  fahrgemeinschaften Fahrgemeinschaft[]
  dokumente          Dokument[]
  workflows          Workflow[]
  hallen             Halle[]
  sponsoren          Sponsor[]
  homepage           Homepage?
  customSportarten   CustomSportart[]
  pinboardItems      PinboardItem[]

  @@index([slug])
}

enum Plan {
  STARTER
  PRO
  CLUB
  ENTERPRISE
  SELF_HOSTED
}

// ==================== Benutzer ====================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  role         Role
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshToken String?
  // E-Mail-Verifizierung
  emailVerifiziert     Boolean  @default(false)
  emailVerifyToken     String?  @unique
  emailVerifyExpiresAt DateTime?
  // Passwort vergessen
  passwortResetToken     String?  @unique
  passwortResetExpiresAt DateTime?
  // Google OAuth
  googleId             String?  @unique
  // Berechtigungen (granulare Freischaltung)
  berechtigungen    String[]   // z.B. ["MITGLIEDER","TEAMS","KALENDER","TURNIERE","NACHRICHTEN","BUCHHALTUNG","FORMULARE","DOKUMENTE","EINSTELLUNGEN"]
  istAktiv          Boolean    @default(true)
  letzterLogin      DateTime?
  eingeladenVon     String?    // userId des Einladenden
  notizen           String?    // Admin-Notizen zum Benutzer
  profile              Member?
  emailEinstellungen   EmailEinstellungen?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([tenantId])
  @@index([email])
}

enum Role {
  SUPERADMIN
  ADMIN
  TRAINER
  MEMBER
  PARENT
}

// ==================== Mitglied ====================

model Member {
  id           String       @id @default(cuid())
  userId       String?      @unique
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberNumber String
  firstName    String
  lastName     String
  email        String?
  birthDate    DateTime?
  phone        String?
  address      String?
  joinDate     DateTime     @default(now())
  exitDate     DateTime?
  status       MemberStatus @default(PENDING)
  sport        String[]
  qrCode       String?
  parentEmail  String?
  signatureUrl String?
  // Beitrag & Ermaessigung
  beitragsArt       String?            // z.B. "Jahresbeitrag Erwachsene", "Jugend", "Familie"
  beitragBetrag     Float?             // Individueller Beitrag (ueberschreibt Standard)
  beitragIntervall  String?            // MONATLICH, QUARTALSWEISE, HALBJAEHRLICH, JAEHRLICH
  ermaessigung      Ermaessigung?      // Ermaessigungsgrund
  ermaessigungProzent Float?           // z.B. 50 fuer 50% Ermaessigung
  ermaessigungBis   DateTime?          // Gueltig bis (z.B. Ende Semester)
  nachweisDokUrl    String?            // Hochgeladener Nachweis (Studentenausweis, etc.)
  nachweisStatus    NachweisStatus     @default(NICHT_ERFORDERLICH)
  nachweisErinnerungGesendet DateTime? // Wann letzte Erinnerung gesendet wurde
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  attendances  Attendance[]
  teamMembers  TeamMember[]

  @@index([tenantId])
  @@index([email])
}

enum MemberStatus {
  PENDING
  ACTIVE
  INACTIVE
  CANCELLED
}

enum Ermaessigung {
  KEINE
  STUDENT           // Studentenausweis erforderlich
  SCHUELER          // Schuelerausweis
  AZUBI             // Ausbildungsnachweis
  RENTNER           // Rentenausweis
  SCHWERBEHINDERT   // Schwerbehindertenausweis
  EHRENAMT          // Ehrenamtlich taetig
  FAMILIE           // Familienermaessigung (ab 2. Mitglied)
  SOZIAL            // Sozialpass / ALG-Bescheid
  SONSTIGE          // Individuell vereinbart
}

enum NachweisStatus {
  NICHT_ERFORDERLICH  // Kein Nachweis noetig
  AUSSTEHEND          // Nachweis fehlt noch
  EINGEREICHT         // Nachweis hochgeladen, wartet auf Pruefung
  GENEHMIGT           // Nachweis geprueft und genehmigt
  ABGELEHNT           // Nachweis abgelehnt
  ABGELAUFEN          // Nachweis ist abgelaufen (z.B. Semester vorbei)
}

// ==================== Abteilung (z.B. Fussball, Handball) ====================

model Abteilung {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String   // z.B. "Fussball", "Handball"
  sport       Sport
  leiterIds   String[] // UserIDs der Abteilungsleiter
  beschreibung String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teams       Team[]

  @@unique([tenantId, sport])
  @@index([tenantId])
}

// ==================== Mannschaft ====================

model Team {
  id           String  @id @default(cuid())
  name         String
  sport        Sport
  ageGroup     String
  trainerId    String
  tenantId     String
  tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  abteilungId  String?
  abteilung    Abteilung? @relation(fields: [abteilungId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  events           Event[]
  messages         Message[]
  teamMembers      TeamMember[]
  hallenbelegungen Hallenbelegung[]
  pinboardItems    PinboardItem[]

  @@index([tenantId])
  @@index([abteilungId])
}

// ==================== Kader (Team-Mitglieder) ====================

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  rolle     String   @default("SPIELER")
  createdAt DateTime @default(now())

  @@unique([teamId, memberId])
  @@index([teamId])
  @@index([memberId])
}

enum Sport {
  FUSSBALL
  HANDBALL
  BASKETBALL
  FOOTBALL
  TENNIS
  TURNEN
  SCHWIMMEN
  LEICHTATHLETIK
  VOLLEYBALL
  TISCHTENNIS
  BADMINTON
  HOCKEY
  RUGBY
  BASEBALL
  SOFTBALL
  EISHOCKEY
  WASSERBALL
  RINGEN
  JUDO
  KARATE
  TAEKWONDO
  BOXEN
  FECHTEN
  REITEN
  GOLF
  KLETTERN
  SKIFAHREN
  SNOWBOARD
  RADSPORT
  TRIATHLON
  RUDERN
  KANU
  SEGELN
  TANZEN
  YOGA
  FITNESS
  CROSSFIT
  WANDERN
  LAUFEN
  DART
  BILLARD
  SCHACH
  ESPORT
  CHEERLEADING
  AKROBATIK
  TRAMPOLINTURNEN
  RHYTHMISCHE_SPORTGYMNASTIK
  EISKUNSTLAUF
  BOGENSCHIESSEN
  SCHIESSEN
  ANGELN
  MOTORSPORT
  FLOORBALL
  LACROSSE
  CRICKET
  SQUASH
  KICKBOXEN
  MMA
  CAPOEIRA
  PARKOUR
  SKATEBOARD
  SURFEN
  TAUCHEN
  WASSERSKI
  GEWICHTHEBEN
  POWERLIFTING
  ROLLSPORT
  PETANQUE
  CURLING
  SONSTIGES
  CUSTOM        // Fuer vom Verein selbst definierte Sportarten
}

// ==================== Eigene Sportarten (pro Verein) ====================

model CustomSportart {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String   // z.B. "Unterwasser-Rugby", "Quidditch"
  beschreibung String?
  icon       String?  // Optionales Icon/Emoji
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
}

// ==================== Veranstaltungen ====================

model Event {
  id          String    @id @default(cuid())
  title       String
  type        EventType
  date        DateTime
  endDate     DateTime?
  location    String
  hallName    String?
  hallAddress String?
  teamId      String
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  notes       String?
  // Wiederkehrende Events
  recurrenceRule  String?   // z.B. "WEEKLY:DI,DO" oder "BIWEEKLY:MI"
  recurrenceEnd   DateTime? // Bis wann wiederholen
  parentEventId   String?   // Referenz auf das Eltern-Event (Vorlage)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  attendances      Attendance[]
  reminders        Reminder[]
  comments         EventComment[]
  schnellTokens    SchnellAnmeldungToken[]
  landingpage      EventLandingpage?

  @@index([tenantId])
  @@index([teamId])
  @@index([date])
}

// ==================== Event-Kommentare ====================

model EventComment {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  content   String
  createdAt DateTime @default(now())

  @@index([eventId])
}

enum EventType {
  TRAINING
  MATCH
  TOURNAMENT
  TRIP
  MEETING
}

// ==================== Anwesenheit ====================

model Attendance {
  id         String           @id @default(cuid())
  eventId    String
  event      Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  memberId   String
  member     Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  status     AttendanceStatus @default(PENDING)
  reason     String?
  answeredAt DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([eventId, memberId])
  @@index([eventId])
  @@index([memberId])
}

enum AttendanceStatus {
  PENDING
  YES
  NO
  MAYBE
}

// ==================== Turnier ====================

model Tournament {
  id        String          @id @default(cuid())
  name      String
  sport     Sport
  format    TournamentFormat
  publicUrl String          @unique
  tenantId  String
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  isLive    Boolean         @default(false)
  qrCode    String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  matches     TournamentMatch[]
  landingpage TurnierLandingpage?

  @@index([tenantId])
  @@index([publicUrl])
}

enum TournamentFormat {
  GRUPPE
  KO
  SCHWEIZER
  KOMBINATION
}

model TournamentMatch {
  id           String      @id @default(cuid())
  tournamentId String
  tournament   Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team1        String
  team2        String
  score1       Int?
  score2       Int?
  time         DateTime?
  field        String?
  status       MatchStatus @default(GEPLANT)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([tournamentId])
}

enum MatchStatus {
  GEPLANT
  LAUFEND
  BEENDET
  ABGESAGT
}

// ==================== Formulare ====================

model FormTemplate {
  id       String   @id @default(cuid())
  tenantId String
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name     String
  type     FormType
  fileUrl  String
  fields   Json
  isActive Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissions FormSubmission[]

  @@index([tenantId])
}

enum FormType {
  MITGLIEDSANTRAG
  EINVERSTAENDNIS
  DATENSCHUTZ
  SONSTIGES
}

// ==================== Formular-Einreichungen (Online-Antraege) ====================

model FormSubmission {
  id             String           @id @default(cuid())
  tenantId       String
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  templateId     String
  template       FormTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  eingereichtVon String?          // userId, falls angemeldet
  email          String           // E-Mail des Antragstellers
  daten          Json             // Ausgefuellte Felder als JSON
  signatureUrl   String?          // Digitale Unterschrift als Data-URL
  signaturDatenUrl String?        // Base64-Signaturdaten (data:image/png;base64,...)
  status         SubmissionStatus @default(EINGEREICHT)
  kommentar      String?          // Interner Kommentar vom Admin
  archiviertePdf String?          // URL der archivierten PDF
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([tenantId])
  @@index([templateId])
  @@index([status])
}

enum SubmissionStatus {
  EINGEREICHT   // Antrag gestellt
  IN_PRUEFUNG   // Wird geprueft
  GENEHMIGT     // Genehmigt → Mitglied wird angelegt
  ABGELEHNT     // Abgelehnt
  ARCHIVIERT    // Archiviert
}

// ==================== Dokumenten-Ablage ====================

model Dokument {
  id          String       @id @default(cuid())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  beschreibung String?
  dateiUrl    String       // Pfad im S3/Storage
  dateiGroesse Int         // Groesse in Bytes
  dateiTyp    String       // MIME-Type (application/pdf, image/png, etc.)
  kategorie   DokumentKategorie @default(SONSTIGES)
  ordner      String?      // Optionaler Ordner-Pfad
  hochgeladenVon String    // userId
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([tenantId])
  @@index([kategorie])
  @@index([ordner])
}

enum DokumentKategorie {
  MITGLIEDSANTRAG
  VERTRAG
  RECHNUNG
  PROTOKOLL
  TRAININGSPLAN
  SATZUNG
  DATENSCHUTZ
  SONSTIGES
}

// ==================== Erinnerungen ====================

model Reminder {
  id           String       @id @default(cuid())
  eventId      String
  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  type         ReminderType
  sentAt       DateTime?
  scheduledFor DateTime
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([eventId])
  @@index([scheduledFor])
}

enum ReminderType {
  H24
  H2
  CUSTOM
}

// ==================== Nachrichten ====================

model Message {
  id         String      @id @default(cuid())
  tenantId   String
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teamId     String?
  team       Team?       @relation(fields: [teamId], references: [id], onDelete: SetNull)
  senderId   String
  content    String
  type        MessageType
  isEmergency Boolean     @default(false)
  silentFrom  String?
  silentTo    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  reads     MessageRead[]
  reactions MessageReaction[]

  @@index([tenantId])
  @@index([teamId])
}

enum MessageType {
  BROADCAST
  ANNOUNCEMENT
  TEAM_CHAT
  QUESTION
  FAQ_ANSWER
}

model MessageRead {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  readAt    DateTime @default(now())

  @@unique([messageId, userId])
  @@index([messageId])
}

// ==================== Nachricht-Reaktionen ====================

model MessageReaction {
  id        String      @id @default(cuid())
  messageId String
  message   Message     @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  reaktion  ReaktionTyp
  createdAt DateTime    @default(now())

  @@unique([messageId, userId])
  @@index([messageId])
}

enum ReaktionTyp {
  GESEHEN
  JA
  NEIN
  VIELLEICHT
}

// ==================== Benachrichtigungs-Einstellungen ====================

model BenachrichtigungsEinstellung {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  pushAktiv              Boolean  @default(true)
  emailAktiv             Boolean  @default(true)
  stilleStundenVon       Int      @default(22)
  stilleStundenBis       Int      @default(7)
  notfallUeberschreiben  Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([userId])
}

// ==================== FAQ ====================

model FAQ {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teamId    String?
  question  String
  answer    String
  useCount  Int      @default(0)
  embedding Json?    // Float-Array fuer Similarity-Suche
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// ==================== Eltern-Fragen ====================

enum FrageStatus {
  OFFEN
  AUTOMATISCH_BEANTWORTET
  BEANTWORTET
}

model ElternFrage {
  id            String       @id @default(cuid())
  tenantId      String
  teamId        String?
  fragenderId   String       // userId des Elternteils
  frage         String
  antwort       String?
  automatisch   Boolean      @default(false)
  status        FrageStatus  @default(OFFEN)
  createdAt     DateTime     @default(now())
  beantwortetAm DateTime?

  @@index([tenantId])
  @@index([teamId])
  @@index([status])
}

// ==================== Schnell-Anmeldung per E-Mail-Link ====================

model SchnellAnmeldungToken {
  id        String   @id @default(cuid())
  token     String   @unique
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  memberId  String
  benutzt   Boolean  @default(false)
  gueltigBis DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([eventId])
}

// ==================== Fahrtenborse ====================

model Fahrgemeinschaft {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  eventId     String?
  fahrerId    String   // userId des Fahrers
  startort    String
  zielort     String
  abfahrt     DateTime
  plaetze     Int      @default(4)
  kommentar   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mitfahrer   Mitfahrer[]

  @@index([tenantId])
  @@index([eventId])
}

model Mitfahrer {
  id                 String           @id @default(cuid())
  fahrgemeinschaftId String
  fahrgemeinschaft   Fahrgemeinschaft @relation(fields: [fahrgemeinschaftId], references: [id], onDelete: Cascade)
  userId             String
  createdAt          DateTime         @default(now())

  @@unique([fahrgemeinschaftId, userId])
  @@index([fahrgemeinschaftId])
}

// ==================== Schiedsrichter-Einteilung ====================

model SchiedsrichterEinteilung {
  id         String   @id @default(cuid())
  tenantId   String
  eventId    String
  memberId   String   // Mitglied das als Schiedsrichter eingeteilt ist
  status     SchiriStatus @default(EINGETEILT)
  bestaetigt Boolean  @default(false)
  notiz      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([eventId, memberId])
  @@index([tenantId])
  @@index([eventId])
}

enum SchiriStatus {
  EINGETEILT
  BESTAETIGT
  ABGELEHNT
  ERSATZ
}

// ==================== Buchhaltung / SEPA ====================

model Rechnung {
  id           String          @id @default(cuid())
  tenantId     String
  memberId     String
  rechnungsNr  String
  betrag       Float
  beschreibung String
  faelligAm    DateTime
  bezahltAm    DateTime?
  status       RechnungStatus  @default(OFFEN)
  sepaMandat   String?         // SEPA-Mandatsreferenz
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([tenantId])
  @@index([memberId])
  @@index([status])
}

enum RechnungStatus {
  OFFEN
  BEZAHLT
  UEBERFAELLIG
  STORNIERT
}

model Beitrag {
  id          String   @id @default(cuid())
  tenantId    String
  name        String   // z.B. "Jahresbeitrag Erwachsene"
  betrag      Float
  intervall   String   // MONATLICH, QUARTALSWEISE, JAEHRLICH
  sportart    String?  // Optional: nur fuer bestimmte Sportart
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

// ==================== Workflows (Einladungs-Pakete) ====================

model Workflow {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String   // z.B. "Neues Mitglied Fussball"
  beschreibung String?  // z.B. "Alle Unterlagen fuer neue Fussball-Mitglieder"
  templateIds  String[] // Welche Formulare gesendet werden
  sportarten   String[] // Vorbelegte Sportarten
  emailBetreff String?  // Optionaler eigener E-Mail-Betreff
  emailText    String?  // Optionaler eigener E-Mail-Text
  istAktiv     Boolean  @default(true)
  erstelltVon  String   // userId des Erstellers (Admin/Vorstand)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
}

// ==================== Hallenbelegung ====================

model Halle {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  adresse       String?
  kapazitaet    Int?
  lat           Float?
  lng           Float?
  mapsUrl       String?
  parkplatzInfo String?
  zugangscode   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  belegungen  Hallenbelegung[]

  @@index([tenantId])
}

model Hallenbelegung {
  id        String   @id @default(cuid())
  halleId   String
  halle     Halle    @relation(fields: [halleId], references: [id], onDelete: Cascade)
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  wochentag String   // MO, DI, MI, DO, FR, SA, SO
  von       String   // "18:00"
  bis       String   // "20:00"
  notiz     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([halleId])
  @@index([teamId])
}

// ==================== Sponsoren ====================

model Sponsor {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  logoUrl      String?
  webseite     String?
  beschreibung String?
  kontaktName  String?
  kontaktEmail String?
  istAktiv     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
}

// ==================== E-Mail-Einstellungen (pro Benutzer) ====================

model EmailEinstellungen {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  smtpHost      String
  smtpPort      Int      @default(587)
  smtpUser      String
  smtpPass      String   // Base64-kodiert gespeichert (TODO: richtige Verschluesselung mit AES-256)
  absenderEmail String   // z.B. trainer.mueller@fcmusterstadt.de
  absenderName  String   // z.B. "Thomas Mueller - FC Musterstadt"
  signatur      String?  // HTML-Signatur fuer E-Mails
  istAktiv      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

// ==================== E-Mail Posteingang ====================

model EmailPosteingang {
  id            String   @id @default(cuid())
  tenantId      String
  empfaengerId  String?  // userId des Empfaengers (null = Vereins-Postfach)
  von           String   // Absender E-Mail
  vonName       String?  // Absender Name
  an            String   // Empfaenger E-Mail
  betreff       String
  inhalt        String   // HTML oder Plain-Text
  inhaltText    String?  // Plain-Text Version
  gelesen       Boolean  @default(false)
  istWichtig    Boolean  @default(false)
  ordner        String      @default("POSTEINGANG")
  anhaenge      String[] // URLs zu Anhaengen
  messageId     String?  // Original Message-ID Header
  inReplyTo     String?  // Referenz auf vorherige Nachricht
  empfangenAm   DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([tenantId])
  @@index([empfaengerId])
  @@index([ordner])
  @@index([empfangenAm])
}

enum EmailOrdner {
  POSTEINGANG
  GESENDET
  ENTWUERFE
  ARCHIV
  PAPIERKORB
}

model EmailEntwurf {
  id            String   @id @default(cuid())
  tenantId      String
  absenderId    String   // userId
  an            String[] // Empfaenger-Adressen
  betreff       String?
  inhalt        String?
  anhaenge      String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([absenderId])
}

// ==================== Profilbild ====================

model Profilbild {
  id        String   @id @default(cuid())
  userId    String   @unique
  bildUrl   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ==================== Vereinshomepage ====================

model Homepage {
  id          String         @id @default(cuid())
  tenantId    String         @unique
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  istAktiv    Boolean        @default(false)
  subdomain   String?        @unique  // z.B. "fckunchen" -> fckunchen.clubos.de
  customDomain String?       @unique  // z.B. "www.fc-kunchen.de"
  // Inhalte
  heroTitel       String?    // z.B. "Willkommen beim FC Kunchen"
  heroUntertitel  String?    // z.B. "Seit 1920 - Ihr Sportverein im Filstal"
  heroBildUrl     String?
  ueberUns        String?    // Freitext HTML/Markdown
  gruendungsjahr  Int?
  mitgliederAnzahl Int?      // Wird automatisch berechnet
  kontaktEmail    String?
  kontaktTelefon  String?
  kontaktAdresse  String?
  oeffnungszeiten String?
  impressum       String?
  datenschutz     String?
  socialFacebook  String?
  socialInstagram String?
  socialYoutube   String?
  // SEO
  seoTitel        String?
  seoBeschreibung String?
  // Design
  headerBildUrl   String?
  footerText      String?
  customCss       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sektionen  HomepageSektion[]

  @@index([tenantId])
  @@index([subdomain])
}

model HomepageSektion {
  id          String   @id @default(cuid())
  homepageId  String
  homepage    Homepage @relation(fields: [homepageId], references: [id], onDelete: Cascade)
  typ         SektionsTyp
  titel       String?
  inhalt      String?    // HTML/Markdown Inhalt
  bildUrl     String?
  reihenfolge Int        @default(0)
  istSichtbar Boolean    @default(true)
  daten       Json?      // Zusaetzliche strukturierte Daten
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([homepageId])
  @@index([reihenfolge])
}

enum SektionsTyp {
  HERO              // Grosses Header-Bild mit Titel
  UEBER_UNS         // Ueber den Verein
  ABTEILUNGEN       // Sportarten/Abteilungen Uebersicht
  MANNSCHAFTEN      // Teams anzeigen
  TERMINE           // Naechste Events/Spiele
  NEUIGKEITEN       // Aktuelles/News
  KONTAKT           // Kontaktformular/Infos
  SPONSOREN         // Sponsor-Logos
  GALERIE           // Bildergalerie
  MITGLIED_WERDEN   // CTA zum Beitreten
  FREITEXT          // Freier HTML-Inhalt
  TURNIER           // Turnier Landing-Page Sektion
}

// ==================== Turnier-Landingpage ====================

model TurnierLandingpage {
  id            String   @id @default(cuid())
  tournamentId  String   @unique
  tournament    Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  istAktiv      Boolean  @default(true)
  slug          String   @unique    // z.B. "hallencup-2026"
  // Inhalte
  titel         String
  beschreibung  String?  // HTML fuer Werbezwecke
  bannerBildUrl String?
  ort           String?
  datum         String?  // Freitext: "14.-15. Juni 2026"
  teilnahmeInfo String?  // Wie teilnehmen
  preise        String?  // Preise/Pokale
  sponsoren     String[] // Sponsor-Namen
  sponsorLogos  String[] // Sponsor-Logo-URLs
  kontaktEmail  String?
  // SEO
  seoTitel        String?
  seoBeschreibung String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

// ==================== Event-Landingpages ====================

model EventLandingpage {
  id              String   @id @default(cuid())
  eventId         String   @unique
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  istAktiv        Boolean  @default(true)
  slug            String   @unique    // z.B. "sommercamp-2026"
  // Inhalte
  titel           String
  beschreibung    String?  // HTML fuer Werbezwecke
  bannerBildUrl   String?
  ort             String?
  datum           String?  // Freitext: "14.-15. Juni 2026"
  zeitplan        String?  // Ablauf/Zeitplan
  anfahrt         String?  // Anfahrtsbeschreibung
  kontaktEmail    String?
  kontaktTelefon  String?
  // SEO
  seoTitel        String?
  seoBeschreibung String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([slug])
}

// ==================== Einladungen ====================

model Einladung {
  id            String          @id @default(cuid())
  tenantId      String
  token         String          @unique
  vorname       String
  nachname      String
  email         String
  templateIds   String[]        // Mehrere Formulare (Antrag, EWE, Datenschutz)
  sportarten    String[]        // Sportarten fuer die Anmeldung
  geburtsdatum  String?         // Optionales Geburtsdatum
  workflowId    String?         // Welcher Workflow verwendet wurde
  status        EinladungStatus @default(GESENDET)
  eingeladenVon String          // userId des Trainers/Vorstands
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([token])
  @@index([tenantId])
}

enum EinladungStatus {
  GESENDET      // E-Mail verschickt
  GEOEFFNET     // Link wurde geklickt
  AUSGEFUELLT   // Formular wurde ausgefuellt
  ABGELAUFEN    // Token abgelaufen (30 Tage)
}

// ==================== Pinboard (Team-Pinnwand) ====================

model PinboardItem {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teamId       String
  team         Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  titel        String
  inhalt       String
  icon         String   @default("info")
  istAngepinnt Boolean  @default(false)
  erstelltVon  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([teamId])
  @@index([tenantId])
}
